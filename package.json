{
  "name": "capaxe-monorepo",
  "private": true,
  "description": "Capaxe Labs monorepo: marketing site + scraper Workers + shared DB schema",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:scrapers": "pnpm --filter scrapers dev",
    "build": "pnpm --filter web build",
    "build:web": "pnpm --filter web build",
    "build:scrapers": "pnpm --filter scrapers build",
    "deploy": "pnpm --filter web run deploy",
    "deploy:web": "pnpm --filter web run deploy",
    "deploy:scrapers": "pnpm --filter scrapers run deploy",
    "check": "pnpm -r check",
    "d1:create": "wrangler d1 create shopify-leads",
    "d1:console": "wrangler d1 execute shopify-leads --remote --command",
    "d1:console:local": "wrangler d1 execute shopify-leads --local --command",
    "d1:import": "node scripts/d1-import.mjs"
  },
  "devDependencies": {
    "typescript": "5.8.3",
    "wrangler": "4.21.x"
  },
  "packageManager": "pnpm@10.5.2"
}