---
import Layout from "../layouts/Layout.astro";
import { createSEO } from "@/utils/seo";
import { getFAQPageSchema } from "@/lib/schemas";

const faqs = [
  {
    question: "Who do you typically work with?",
    answer: "Considered Shopify brands that have moved past the template-and-plugin stage — usually direct-to-consumer brands where the store is the operating system of the business, not a brochure. We work best with operators who care about the line between engineering and revenue."
  },
  {
    question: "How is this different from a typical Shopify agency?",
    answer: "Most Shopify agencies are studios that picked up code; we're engineers who picked up Shopify. We engineer systems — conversion, merchandising, performance, custom — not deliverables. The discipline comes from years of shipping production systems at scale, including in fintech."
  },
  {
    question: "Do you take on early-stage stores or one-off projects?",
    answer: "Generally, no. The brands we work with already have traction and have outgrown the systems they started with. Early-stage stores are usually better served by a theme partner or a dedicated solo developer."
  },
  {
    question: "How long does an engagement take?",
    answer: "Diagnostics typically run a few weeks. Build sprints are scoped to the system being engineered. Embedded partnerships are ongoing. We share a clear timeline before any work begins."
  },
  {
    question: "Do you publish pricing?",
    answer: "No — and we think that's a feature. No two engagements look the same, and fixed published pricing tends to push agencies toward template work rather than engineered work. We give you a clear investment range in the first conversation."
  },
  {
    question: "Where are you based and how do you work with international brands?",
    answer: "We're based in India and work with brands across multiple time zones. Our engagements are async-first, with structured sync touchpoints — designed to feel like an embedded internal team rather than an external vendor."
  },
  {
    question: "Do you work on Shopify Plus?",
    answer: "Yes. The systems we engineer — conversion, merchandising, performance, custom — apply across Shopify and Shopify Plus, with deeper engineering on Plus where Functions, B2B, and headless make more sense."
  }
];

const seo = createSEO({
  pageName: "Shopify Development FAQ",
  description: "Answers to common questions about Capaxe Labs' Shopify services — custom apps, headless commerce, payment integrations, retainer plans, timelines, and pricing.",
  keywords: "Shopify development FAQ, Shopify agency questions, Shopify app development FAQ, headless commerce FAQ",
  contentType: "faq",
  pathname: "/faq"
});
seo.structuredData = getFAQPageSchema(faqs);
---

<Layout seo={seo}>
  <main class="min-h-screen">
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-5xl font-bold mb-4 text-foreground">Frequently Asked Questions</h1>
        <p class="text-lg text-muted-foreground mb-8">Find answers to common questions about our services, processes, and how we can help your business grow online.</p>
      </div>
    </section>

    <!-- FAQ Categories -->
    <section class="px-6 pb-4">
      <div class="max-w-3xl mx-auto">
        <div class="flex flex-wrap justify-center gap-2 mb-8">
          <button class="px-5 py-2 bg-primary-500 text-white text-sm rounded-full font-medium">All</button>
          <button class="px-5 py-2 bg-foreground/5 text-muted-foreground hover:text-foreground hover:bg-foreground/10 text-sm rounded-full transition-colors">Services</button>
          <button class="px-5 py-2 bg-foreground/5 text-muted-foreground hover:text-foreground hover:bg-foreground/10 text-sm rounded-full transition-colors">Process</button>
          <button class="px-5 py-2 bg-foreground/5 text-muted-foreground hover:text-foreground hover:bg-foreground/10 text-sm rounded-full transition-colors">Pricing</button>
          <button class="px-5 py-2 bg-foreground/5 text-muted-foreground hover:text-foreground hover:bg-foreground/10 text-sm rounded-full transition-colors">Support</button>
        </div>
      </div>
    </section>

    <!-- FAQ Items -->
    <section class="px-6 pb-16">
      <div class="max-w-3xl mx-auto space-y-3">
        {faqs.map((faq, index) => (
          <div class="faq-item bento-tile p-0 overflow-hidden">
            <button class="flex justify-between items-center w-full px-6 py-5 text-left hover:bg-foreground/5 transition-colors">
              <span class="text-sm font-medium text-foreground pr-4">{faq.question}</span>
              <svg class="h-5 w-5 text-muted-foreground flex-shrink-0 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div class={index === 0 ? "px-6 pb-5" : "hidden px-6 pb-5"}>
              <p class="text-sm text-muted-foreground leading-relaxed">{faq.answer}</p>
            </div>
          </div>
        ))}

        <div class="bento-tile-accent text-center mt-8 py-10">
          <p class="text-lg text-white/80 mb-4">Don't see your question here?</p>
          <a href="/contact" class="inline-block bg-white text-primary-600 py-2.5 px-6 rounded-xl text-sm font-medium hover:bg-gray-100 transition-colors">
            Contact Us
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const faqItems = document.querySelectorAll(".faq-item");

    faqItems.forEach((item) => {
      const button = item.querySelector("button");
      button?.addEventListener("click", () => {
        const content = button.nextElementSibling as HTMLElement | null;
        if (content) {
          content.classList.toggle("hidden");
          const svg = button.querySelector("svg");
          if (svg) {
            svg.classList.toggle("rotate-180");
          }
        }
      });
    });
  });
</script>
