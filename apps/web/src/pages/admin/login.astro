---
export const prerender = false;

import "@/styles/global.css";

const url = new URL(Astro.request.url);
const error = url.searchParams.get("error");
const nextParam = url.searchParams.get("next") || "/admin";

// Handle POST login here (same route, simpler than separate API)
let formError: string | null = null;
if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const token = String(data.get("token") ?? "");
  const expected = Astro.locals.runtime?.env?.ADMIN_TOKEN;
  if (expected && token === expected) {
    Astro.cookies.set("admin_token", token, {
      path: "/",
      httpOnly: true,
      secure: true,
      sameSite: "lax",
      maxAge: 60 * 60 * 24 * 30, // 30 days
    });
    return Astro.redirect(String(data.get("next") || "/admin"));
  }
  formError = "Invalid token";
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Sign in — Capaxe Admin</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased flex items-center justify-center">
    <div class="w-full max-w-sm rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <h1 class="text-lg font-semibold tracking-tight">Capaxe Admin</h1>
      <p class="mt-1 text-sm text-slate-600">Enter the admin token to continue.</p>

      {(formError || error) && (
        <div class="mt-4 rounded-md bg-red-50 px-3 py-2 text-sm text-red-700">
          {formError ?? error}
        </div>
      )}

      <form method="POST" class="mt-5 space-y-3">
        <input type="hidden" name="next" value={nextParam} />
        <input
          name="token"
          type="password"
          required
          autocomplete="current-password"
          placeholder="Token"
          class="block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-900 focus:outline-none focus:ring-1 focus:ring-slate-900"
        />
        <button
          type="submit"
          class="w-full rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-800"
        >
          Sign in
        </button>
      </form>
    </div>
  </body>
</html>
