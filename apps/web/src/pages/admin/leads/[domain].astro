---
import AdminLayout from "@/layouts/AdminLayout.astro";

export const prerender = false;

const db = Astro.locals.runtime.env.LEADS_DB;
const domain = decodeURIComponent(Astro.params.domain ?? "").toLowerCase();

// Handle PATCH-style POST for admin_status / admin_notes / admin_owner
if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const status = String(data.get("admin_status") ?? "");
  const notes = String(data.get("admin_notes") ?? "");
  const owner = String(data.get("admin_owner") ?? "");
  await db
    .prepare(
      `UPDATE parsed_stores SET
          admin_status = NULLIF(?, ''),
          admin_notes = NULLIF(?, ''),
          admin_owner = NULLIF(?, ''),
          admin_updated_at = CURRENT_TIMESTAMP
        WHERE website = ?`
    )
    .bind(status, notes, owner, domain)
    .run();
  return Astro.redirect(Astro.url.pathname + "?saved=1");
}

const saved = Astro.url.searchParams.get("saved") === "1";

const ps = await db
  .prepare("SELECT * FROM parsed_stores WHERE website = ? LIMIT 1")
  .bind(domain)
  .first<Record<string, any>>();

const js = await db
  .prepare("SELECT * FROM judgeme_stores WHERE storefront = ? LIMIT 1")
  .bind(domain)
  .first<Record<string, any>>();

const rs = await db
  .prepare(
    "SELECT rank, website_popularity, scraped_at FROM raw_stores WHERE website = ? ORDER BY scraped_at DESC LIMIT 1"
  )
  .bind(domain)
  .first<{ rank: string | null; website_popularity: string | null; scraped_at: string | null }>();

// Resolve apps
let installedApps: Array<{ id: number; name: string; vendor_name: string | null; install_count: number | null; avg_rating: number | null; app_store_url: string | null }> = [];
if (ps?.apps) {
  try {
    const ids = JSON.parse(ps.apps);
    if (Array.isArray(ids) && ids.length > 0) {
      const placeholders = ids.map(() => "?").join(",");
      const r = await db
        .prepare(`SELECT id, name, vendor_name, install_count, avg_rating, app_store_url FROM apps WHERE id IN (${placeholders}) ORDER BY install_count DESC NULLS LAST, name`)
        .bind(...ids)
        .all<{ id: number; name: string; vendor_name: string | null; install_count: number | null; avg_rating: number | null; app_store_url: string | null }>();
      installedApps = r.results ?? [];
    }
  } catch {}
}

// Resolve theme
let theme: { id: number; name: string; vendor: string | null; style_handle: string | null; theme_store_url: string | null } | null = null;
if (ps?.theme_id) {
  theme = await db
    .prepare("SELECT id, name, vendor, style_handle, theme_store_url FROM themes WHERE id = ?")
    .bind(ps.theme_id)
    .first();
}

// Resolve judgeme category
let category: { id: number; name: string } | null = null;
if (js?.category_id) {
  category = await db
    .prepare("SELECT id, name FROM judgeme_categories WHERE id = ?")
    .bind(js.category_id)
    .first();
}

const socials = (() => {
  try { return JSON.parse(ps?.social_handles || "{}") as Record<string, string>; } catch { return {} as Record<string, string>; }
})();

function fmt(n: number | null | undefined) { return n == null ? "—" : n.toLocaleString("en-US"); }

const fieldGroups = ps ? {
  Identity: ["merchant_name", "company_name", "title", "description", "myshopify_domain"],
  Geo: ["country", "country_code", "region", "state", "city", "location", "language", "currency"],
  Commercial: ["plan", "storeleads_rank", "avg_price_formatted", "min_price_formatted", "max_price_formatted", "est_revenue_formatted", "est_yearly_revenue_formatted"],
  Catalog: ["product_count", "collection_count", "product_count_30d", "product_count_90d", "product_count_365d"],
  Contact: ["email", "phone"],
  Reviews: ["judgeme_review_count", "judgeme_avg_rating"],
  Theme: ["theme_id", "theme_raw", "theme_version"],
  Provenance: ["data_source", "processed_at", "storeleads_imported_at", "storeleads_last_crawled", "store_created_at"],
  Assets: ["favicon_url", "og_image_url"],
} : {};
---

<AdminLayout title={domain} active="leads">
  <div class="mb-4">
    <a href="/admin/leads" class="text-xs text-slate-500 hover:underline">← Back to leads</a>
  </div>

  <div class="flex items-start justify-between">
    <div>
      <h2 class="text-xl font-semibold tracking-tight">{ps?.merchant_name || ps?.company_name || domain}</h2>
      <p class="mt-0.5 text-sm text-slate-600">
        <a href={`https://${domain}`} target="_blank" rel="noopener" class="hover:underline">{domain} ↗</a>
        {ps?.myshopify_domain && <span class="text-slate-400"> · {ps.myshopify_domain}</span>}
      </p>
    </div>
    {ps?.favicon_url && <img src={ps.favicon_url} alt="" class="h-10 w-10 rounded border border-slate-200" />}
  </div>

  {!ps && (
    <div class="mt-6 rounded-md bg-amber-50 px-4 py-3 text-sm text-amber-800">
      No entry for <strong>{domain}</strong> in parsed_stores.
    </div>
  )}

  {saved && (
    <div class="mt-4 rounded-md bg-emerald-50 px-3 py-2 text-sm text-emerald-700">Saved.</div>
  )}

  <div class="mt-6 grid grid-cols-1 gap-6 lg:grid-cols-3">
    <!-- Left: 2-col data -->
    <div class="lg:col-span-2 space-y-6">
      {Object.entries(fieldGroups).map(([group, fields]) => {
        const visible = (fields as string[]).filter((f) => ps?.[f] != null && ps?.[f] !== "");
        if (!visible.length) return null;
        return (
          <div class="rounded-lg border border-slate-200 bg-white p-4">
            <h3 class="text-sm font-medium">{group}</h3>
            <dl class="mt-3 grid grid-cols-1 gap-x-6 gap-y-1.5 text-sm sm:grid-cols-2">
              {visible.map((f) => (
                <div>
                  <dt class="text-xs uppercase tracking-wider text-slate-500">{f}</dt>
                  <dd class="break-words text-slate-800">{String(ps[f]).slice(0, 200)}</dd>
                </div>
              ))}
            </dl>
          </div>
        );
      })}

      {theme && (
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <h3 class="text-sm font-medium">Theme</h3>
          <p class="mt-2 text-sm">
            <a href={theme.theme_store_url ?? "#"} target="_blank" rel="noopener" class="font-medium text-slate-900 hover:underline">{theme.name}</a>
            {theme.style_handle && <span class="text-slate-500"> ({theme.style_handle})</span>}
            {theme.vendor && <span class="text-slate-500"> · by {theme.vendor}</span>}
            {ps?.theme_version && <span class="text-slate-500"> · v{ps.theme_version}</span>}
          </p>
        </div>
      )}

      {installedApps.length > 0 && (
        <div class="rounded-lg border border-slate-200 bg-white">
          <h3 class="border-b border-slate-200 px-4 py-3 text-sm font-medium">Installed apps ({installedApps.length})</h3>
          <table class="w-full text-sm">
            <thead class="bg-slate-50 text-xs uppercase tracking-wider text-slate-500">
              <tr><th class="px-4 py-2 text-left font-medium">App</th><th class="px-4 py-2 text-left font-medium">Vendor</th><th class="px-4 py-2 text-right font-medium">Installs</th><th class="px-4 py-2 text-right font-medium">Rating</th></tr>
            </thead>
            <tbody>
              {installedApps.map((a) => (
                <tr class="border-t border-slate-100">
                  <td class="px-4 py-2 font-medium">
                    {a.app_store_url ? <a href={a.app_store_url} target="_blank" rel="noopener" class="text-slate-900 hover:underline">{a.name}</a> : a.name}
                  </td>
                  <td class="px-4 py-2 text-slate-600">{a.vendor_name ?? "—"}</td>
                  <td class="px-4 py-2 text-right text-slate-700">{fmt(a.install_count)}</td>
                  <td class="px-4 py-2 text-right text-slate-700">{a.avg_rating != null ? a.avg_rating.toFixed(1) : "—"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {js && (
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <h3 class="text-sm font-medium">Judge.me data</h3>
          <dl class="mt-3 grid grid-cols-2 gap-x-6 gap-y-1.5 text-sm">
            <div><dt class="text-xs uppercase tracking-wider text-slate-500">Reviews</dt><dd>{fmt(js.reviews_count)} ({fmt(js.verified_reviews)} verified)</dd></div>
            <div><dt class="text-xs uppercase tracking-wider text-slate-500">Average rating</dt><dd>{js.avg_rating != null ? js.avg_rating.toFixed(2) : "—"}</dd></div>
            <div><dt class="text-xs uppercase tracking-wider text-slate-500">Transparency</dt><dd>{js.transparency_score != null ? (js.transparency_score * 100).toFixed(0) + "%" : "—"}</dd></div>
            <div><dt class="text-xs uppercase tracking-wider text-slate-500">Authenticity</dt><dd>{js.authenticity_score != null ? (js.authenticity_score * 100).toFixed(0) + "%" : "—"}</dd></div>
            {category && <div><dt class="text-xs uppercase tracking-wider text-slate-500">Category</dt><dd>{category.name}</dd></div>}
            {js.top_product_url && <div class="col-span-2"><dt class="text-xs uppercase tracking-wider text-slate-500">Top product</dt><dd><a href={js.top_product_url} target="_blank" rel="noopener" class="hover:underline">{js.top_product_title ?? js.top_product_url}</a> {js.top_product_price && <span class="text-slate-500"> · {js.top_product_price}</span>}</dd></div>}
          </dl>
        </div>
      )}

      {rs && (
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <h3 class="text-sm font-medium">myip.ms data</h3>
          <dl class="mt-3 grid grid-cols-2 gap-x-6 gap-y-1.5 text-sm">
            <div><dt class="text-xs uppercase tracking-wider text-slate-500">Rank</dt><dd>{rs.rank ?? "—"}</dd></div>
            <div><dt class="text-xs uppercase tracking-wider text-slate-500">Daily visitors</dt><dd>{rs.website_popularity ?? "—"}</dd></div>
            <div class="col-span-2"><dt class="text-xs uppercase tracking-wider text-slate-500">Scraped</dt><dd class="text-slate-500">{rs.scraped_at ?? "—"}</dd></div>
          </dl>
        </div>
      )}
    </div>

    <!-- Right column: admin workflow + socials -->
    <div class="space-y-6">
      <div class="rounded-lg border border-slate-200 bg-white p-4">
        <h3 class="text-sm font-medium">Outreach</h3>
        <form method="POST" class="mt-3 space-y-3">
          <div>
            <label class="block text-xs uppercase tracking-wider text-slate-500">Status</label>
            <select name="admin_status" class="mt-1 w-full rounded-md border border-slate-300 px-2 py-1.5 text-sm">
              <option value="" selected={!ps?.admin_status}>—</option>
              <option value="new" selected={ps?.admin_status === "new"}>new</option>
              <option value="contacted" selected={ps?.admin_status === "contacted"}>contacted</option>
              <option value="interested" selected={ps?.admin_status === "interested"}>interested</option>
              <option value="deal" selected={ps?.admin_status === "deal"}>deal</option>
              <option value="rejected" selected={ps?.admin_status === "rejected"}>rejected</option>
            </select>
          </div>
          <div>
            <label class="block text-xs uppercase tracking-wider text-slate-500">Owner</label>
            <input
              name="admin_owner"
              type="text"
              value={ps?.admin_owner ?? ""}
              placeholder="Mukesh"
              class="mt-1 w-full rounded-md border border-slate-300 px-2 py-1.5 text-sm"
            />
          </div>
          <div>
            <label class="block text-xs uppercase tracking-wider text-slate-500">Notes</label>
            <textarea
              name="admin_notes"
              rows="5"
              class="mt-1 w-full rounded-md border border-slate-300 px-2 py-1.5 text-sm"
            >{ps?.admin_notes ?? ""}</textarea>
          </div>
          <button type="submit" class="w-full rounded-md bg-slate-900 px-3 py-1.5 text-sm font-medium text-white hover:bg-slate-800">Save</button>
        </form>
        {ps?.admin_updated_at && <p class="mt-2 text-xs text-slate-500">Updated {ps.admin_updated_at}</p>}
      </div>

      {Object.keys(socials).length > 0 && (
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <h3 class="text-sm font-medium">Socials</h3>
          <ul class="mt-3 space-y-1 text-sm">
            {Object.entries(socials).map(([k, v]) => (
              <li><span class="text-xs uppercase tracking-wider text-slate-500 w-20 inline-block">{k}</span> <a href={v} target="_blank" rel="noopener" class="text-slate-700 hover:underline break-all">{v}</a></li>
            ))}
          </ul>
        </div>
      )}

      {(ps?.email || ps?.phone) && (
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <h3 class="text-sm font-medium">Contact</h3>
          <dl class="mt-3 space-y-1.5 text-sm">
            {ps?.email && <div><dt class="text-xs uppercase tracking-wider text-slate-500">Email</dt><dd><a href={`mailto:${ps.email}`} class="hover:underline">{ps.email}</a></dd></div>}
            {ps?.phone && <div><dt class="text-xs uppercase tracking-wider text-slate-500">Phone</dt><dd>{ps.phone}</dd></div>}
          </dl>
        </div>
      )}
    </div>
  </div>
</AdminLayout>
