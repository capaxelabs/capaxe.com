---
import Layout from "@/layouts/Layout.astro";
import { siteConfig } from "@/config/site";
import { StickyCards, ServiceLanding } from "@/components/home/HomeComponents";
import RetainerPlansSection from "@/components/RetainerPlan";
import HeroSection from "@/components/home/HeroSection.astro";
import ClientLogos from "@/components/home/ClientLogos.astro";
import AppPartners from "@/components/home/AppPartners.astro";
import OfficialPartners from "@/components/home/OfficialPartners.astro";
import FAQSection from "@/components/FAQSection.astro";
import { createSEO } from "@/utils/seo";
import { getEnhancedOrganizationSchema } from "@/lib/schemas";

const faqs = [
  { question: "What Shopify development services does Capaxe Labs offer?", answer: "We offer custom Shopify app development, Liquid theme builds, headless storefronts with Hydrogen, Shopify Plus enterprise solutions, store migrations, and ongoing maintenance retainer plans." },
  { question: "How much does a Shopify development project cost?", answer: "Project costs vary based on scope. Custom themes start around $3,000, while custom apps and headless builds range from $5,000 to $25,000+. We offer free consultations to provide accurate estimates." },
  { question: "Do you offer ongoing Shopify support after launch?", answer: "Yes, we offer flexible retainer plans starting at $999/month that include dedicated developer access, bug fixes, feature enhancements, and priority support." },
  { question: "How long does a typical Shopify project take?", answer: "Simple theme customizations take 1-2 weeks. Custom themes take 4-6 weeks. Custom apps and headless builds typically take 6-12 weeks depending on complexity." },
  { question: "Can you migrate my store from another platform to Shopify?", answer: "Yes, we handle full migrations from WooCommerce, Magento, BigCommerce, and other platforms to Shopify, including product data, customer records, and order history." },
];

const seo = createSEO({
  pageName: "Shopify Development Agency — Liquid Themes, Custom Apps & Headless Storefronts",
  description: "Mumbai-based Shopify development agency specializing in Liquid themes, custom apps, and headless storefronts. From theme builds to Hydrogen commerce — we ship it all.",
  keywords: "Shopify development agency, custom Shopify apps, headless Shopify, Shopify Plus development, Shopify store development, headless commerce",
  contentType: "basic",
  pathname: "/",
});
seo.structuredData = getEnhancedOrganizationSchema();
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <HeroSection />

    <OfficialPartners />

    <div class="max-w-7xl mx-auto px-6">
      <div class="h-px bg-linear-to-r from-transparent via-border to-transparent"></div>
    </div>

    <ClientLogos />

    <div class="max-w-7xl mx-auto px-6">
      <div class="h-px bg-linear-to-r from-transparent via-border to-transparent"></div>
    </div>

    <StickyCards siteConfig={siteConfig} client:visible />

    <div class="max-w-7xl mx-auto px-6">
      <div class="h-px bg-linear-to-r from-transparent via-border to-transparent"></div>
    </div>

    <ServiceLanding siteConfig={siteConfig} client:visible />

    <div class="max-w-7xl mx-auto px-6">
      <div class="h-px bg-linear-to-r from-transparent via-border to-transparent"></div>
    </div>

    <AppPartners />

    <div class="max-w-7xl mx-auto px-6">
      <div class="h-px bg-linear-to-r from-transparent via-border to-transparent"></div>
    </div>

    <div class="reveal-on-scroll">
      <RetainerPlansSection client:visible />
    </div>

    <FAQSection faqs={faqs} />
  </div>
</Layout>
