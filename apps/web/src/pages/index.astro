---
import Layout from "@/layouts/Layout.astro";
import HeroSection from "@/components/home/HeroSection.astro";
import ClientLogos from "@/components/home/ClientLogos.astro";
import OfficialPartners from "@/components/home/OfficialPartners.astro";
import CeilingSection from "@/components/home/CeilingSection.astro";
import FourSystems from "@/components/home/FourSystems.astro";
import HowWeWork from "@/components/home/HowWeWork.astro";
import WhoBuiltFor from "@/components/home/WhoBuiltFor.astro";
import FounderSection from "@/components/home/FounderSection.astro";
import FinalCTASection from "@/components/home/FinalCTASection.astro";
import FAQSection from "@/components/FAQSection.astro";
import { createSEO } from "@/utils/seo";
import { getEnhancedOrganizationSchema } from "@/lib/schemas";

const faqs = [
  { question: "Who do you typically work with?", answer: "Considered Shopify brands that have moved past the template-and-plugin stage — usually direct-to-consumer brands where the store is the operating system of the business, not a brochure. We work best with operators who care about the line between engineering and revenue." },
  { question: "How is this different from a typical Shopify agency?", answer: "Most Shopify agencies are studios that picked up code; we're engineers who picked up Shopify. We engineer systems — conversion, merchandising, performance, custom — not deliverables. The discipline comes from years of shipping production systems at scale, including in fintech." },
  { question: "Do you take on early-stage stores or one-off projects?", answer: "Generally, no. The brands we work with already have traction and have outgrown the systems they started with. Early-stage stores are usually better served by a theme partner or a dedicated solo developer." },
  { question: "How long does an engagement take?", answer: "Diagnostics typically run a few weeks. Build sprints are scoped to the system being engineered. Embedded partnerships are ongoing. We share a clear timeline before any work begins." },
  { question: "Do you publish pricing?", answer: "No — and we think that's a feature. No two engagements look the same, and fixed published pricing tends to push agencies toward template work rather than engineered work. We give you a clear investment range in the first conversation." },
  { question: "Where are you based and how do you work with international brands?", answer: "We're based in India and work with brands across multiple time zones. Our engagements are async-first, with structured sync touchpoints — designed to feel like an embedded internal team rather than an external vendor." },
  { question: "Do you work on Shopify Plus?", answer: "Yes. The systems we engineer — conversion, merchandising, performance, custom — apply across Shopify and Shopify Plus, with deeper engineering on Plus where Functions, B2B, and headless make more sense." },
];

const seo = createSEO({
  pageName: "Shopify Systems Engineering for Brands Past Templates, Apps, and Quick Fixes",
  description: "Capaxe Labs engineers the systems behind considered Shopify brands — conversion, merchandising, performance, and custom engineering. Built by engineers, not a theme shop.",
  keywords: "Shopify systems engineering, Shopify Plus development, headless Shopify, Shopify conversion engineering, Shopify performance engineering, custom Shopify apps, Shopify Functions",
  contentType: "basic",
  pathname: "/",
});
seo.structuredData = getEnhancedOrganizationSchema();
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <HeroSection />

    <OfficialPartners />

    <ClientLogos />

    <CeilingSection />

    <FourSystems />

    <HowWeWork />

    <WhoBuiltFor />

    <FounderSection />

    <FinalCTASection />

    <FAQSection faqs={faqs} />
  </div>
</Layout>
