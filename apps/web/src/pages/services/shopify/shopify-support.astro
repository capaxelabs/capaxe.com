---
import Layout from "@/layouts/Layout.astro";
import CTABottom from "@/components/CTA.astro";
import ServiceCTA from "@/components/ServiceCTA";
import FAQSection from "@/components/FAQSection.astro";
import { createSEO } from "@/utils/seo";

const faqs = [
  { question: "What kind of Shopify technical support do you provide?", answer: "We handle bug fixes, theme issues, app conflicts, checkout problems, performance optimization, and custom feature requests. Our team knows Shopify inside and out." },
  { question: "What are your support response times?", answer: "Critical issues get a response within 2-4 hours. Standard requests are addressed within 1 business day. We offer priority plans with faster SLAs for mission-critical stores." },
  { question: "Do you offer ongoing Shopify support plans?", answer: "Yes. We offer monthly retainer plans with dedicated hours for ongoing support, maintenance, and small development tasks. Plans are flexible and scale with your needs." },
  { question: "Can you fix issues caused by third-party Shopify apps?", answer: "Yes. We diagnose and resolve app conflicts, broken integrations, and performance issues caused by third-party apps. We also recommend better alternatives when needed." },
  { question: "Do you provide emergency support for store outages?", answer: "Yes. We offer emergency support for critical issues like checkout failures, payment gateway errors, and site downtime. We prioritize getting your store back online fast." },
];

const seo = createSEO({
  pageName: "Shopify Technical Support",
  description: "Get expert priority technical support for your Shopify store. Our team provides round-the-clock assistance, regular maintenance, security patches, and fast troubleshooting to keep your business running smoothly.",
  keywords: "technical support, Priority Support, expert support, digital presence, website support, e-commerce support",
  image: "/images/services/technical-support.jpg",
  contentType: "service",
  pathname: "/services/shopify/shopify-support"
});
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20">
            Priority Support
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4">Technical Support</h1>
          <p class="text-lg text-white/60 max-w-2xl mx-auto">
            We're here when you need us. Our team provides expert priority support for your entire team's questions and queries, getting to know your store inside out to be your trusted partner.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-grid grid-cols-1 md:grid-cols-3">
          <div class="bento-tile text-center">
            <h2 class="text-xl font-semibold text-foreground mb-2">Priority Support</h2>
            <p class="text-sm text-muted-foreground">Round-the-clock technical support for your critical business needs.</p>
          </div>
          <div class="bento-tile-accent text-center">
            <h2 class="text-xl font-semibold mb-2">Maintenance Services</h2>
            <p class="text-sm text-white/70">Regular updates, security patches, and performance optimization.</p>
          </div>
          <div class="bento-tile text-center">
            <h2 class="text-xl font-semibold text-foreground mb-2">Expert Troubleshooting</h2>
            <p class="text-sm text-muted-foreground">Quick resolution of technical issues and expert problem-solving.</p>
          </div>
        </div>
      </div>
    </section>
    <FAQSection faqs={faqs} />
    <ServiceCTA />
  </div>
  <CTABottom />
</Layout>
