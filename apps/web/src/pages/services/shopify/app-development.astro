---
import { FiCode, FiTool, FiCloud } from "react-icons/fi";
import CTABottom from "@/components/CTA.astro";
import Layout from "@/layouts/Layout.astro";
import ServiceCTA from "@/components/ServiceCTA";
import FAQSection from "@/components/FAQSection.astro";
import { createSEO } from "@/utils/seo";

const faqs = [
  { question: "What types of custom Shopify apps can you build?", answer: "We build private apps, custom admin tools, third-party integrations, checkout extensions, and Shopify Functions. Each app is tailored to your specific business workflows." },
  { question: "How long does it take to develop a custom Shopify app?", answer: "Simple apps take 2-4 weeks, while complex apps with multiple integrations take 6-12 weeks. We provide a detailed timeline after the discovery phase." },
  { question: "Can you integrate my existing systems with Shopify?", answer: "Yes, we build custom integrations with ERPs, CRMs, warehouse systems, and any third-party API. We ensure real-time data sync and error handling." },
  { question: "Do you provide ongoing support after the app is built?", answer: "Absolutely. We offer maintenance plans that include bug fixes, updates for new Shopify API versions, and feature enhancements as your business grows." },
  { question: "What tech stack do you use for Shopify app development?", answer: "We use TypeScript, React, Node.js, Shopify Polaris, GraphQL, and Prisma. Apps are deployed on Cloudflare Workers or Vercel for optimal performance." },
];

const seo = createSEO({
  pageName: "Custom App Development",
  description: "Expert Shopify custom app development services to extend your store's functionality with tailor-made solutions for your unique business needs.",
  keywords: "shopify app development, custom shopify apps, shopify development services, e-commerce apps",
  image: "/images/services/custom-app-development.jpg",
  contentType: "service",
  pathname: "/services/shopify/app-development"
});
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20">
            Custom Apps
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4">Custom App Development</h1>
          <p class="text-lg text-white/60 max-w-2xl mx-auto">
            Take your Shopify store to the next level with our expert app development services. Whether it's a custom app tailored to your business needs or a public app designed to serve thousands of merchants, we've got you covered.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-grid grid-cols-1 md:grid-cols-3">
          <div class="bento-tile md:col-span-2 text-center">
            <FiCode className="text-3xl text-primary-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Custom App Development</h2>
            <p class="text-sm text-muted-foreground">Build apps tailored to your specific requirements, integrating unique features that make your store stand out.</p>
          </div>
          <div class="bento-tile-accent text-center">
            <FiTool className="text-3xl text-white/80 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold mb-2">Public App Development</h2>
            <p class="text-sm text-white/70">Create scalable public apps that can be listed on the Shopify App Store to reach a global audience.</p>
          </div>
          <div class="bento-tile text-center">
            <FiCloud className="text-3xl text-violet-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Seamless Integrations</h2>
            <p class="text-sm text-muted-foreground">Integrate third-party tools and services seamlessly into your Shopify store for enhanced functionality.</p>
          </div>
        </div>
      </div>
    </section>
    <FAQSection faqs={faqs} />
    <ServiceCTA />
  </div>
  <CTABottom />
</Layout>
