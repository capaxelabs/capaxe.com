---
import { FiArrowRight, FiRefreshCcw, FiDatabase, FiSettings } from "react-icons/fi";
import CTABottom from "@/components/CTA.astro";
import Layout from "@/layouts/Layout.astro";
import ServiceCTA from "@/components/ServiceCTA";
import FAQSection from "@/components/FAQSection.astro";
import { createSEO } from "@/utils/seo";

const faqs = [
  { question: "How long does a Shopify migration take?", answer: "Simple stores migrate in 2-4 weeks. Stores with thousands of products and complex integrations take 6-12 weeks. We run test migrations first to ensure accuracy." },
  { question: "Will I lose my SEO rankings during migration?", answer: "No. We set up comprehensive 301 redirects for every URL, preserve meta tags, and submit updated sitemaps. Most clients maintain or improve their rankings." },
  { question: "What data gets migrated to Shopify?", answer: "We migrate products, customers, orders, reviews, blog posts, pages, and discount codes. Every data point is verified for accuracy after transfer." },
  { question: "Can you integrate third-party tools with my Shopify store?", answer: "Yes, we integrate CRMs, ERPs, shipping providers, marketing platforms, and accounting software. We build custom API connections when needed." },
  { question: "Do you support migration from any e-commerce platform?", answer: "We regularly migrate from WooCommerce, Magento, BigCommerce, Squarespace, and custom platforms. We build custom migration scripts for non-standard setups." },
];

const seo = createSEO({
  pageName: "Migration & Integration",
  description: "Seamlessly migrate your online store to Shopify from WooCommerce, BigCommerce, or Magento with zero data loss and minimal downtime. We also integrate third-party tools like CRMs, ERPs, and marketing platforms.",
  keywords: "shopify migration, ecommerce migration, integration services, e-commerce migration, shopify integration, woocommerce to shopify, bigcommerce to shopify, magento to shopify",
  image: "/images/services/migration-integration.jpg",
  contentType: "service",
  pathname: "/services/migration-integration"
});
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20">
            Platform Migration
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4">Migration & Integration</h1>
          <p class="text-lg text-white/60 max-w-2xl mx-auto">
            Transition your online store to Shopify seamlessly. We specialize in migrating from WooCommerce, BigCommerce, and Magento while ensuring data integrity and minimal downtime.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-grid grid-cols-1 lg:grid-cols-3">
          <div class="bento-tile md:col-span-2 text-center">
            <FiArrowRight className="text-3xl text-primary-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">WooCommerce to Shopify</h2>
            <p class="text-sm text-muted-foreground">Migrate from WooCommerce to Shopify with ease, preserving all your products, orders, and customer data.</p>
          </div>
          <div class="bento-tile-accent text-center">
            <FiRefreshCcw className="text-3xl text-white/80 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold mb-2">BigCommerce to Shopify</h2>
            <p class="text-sm text-white/70">Transition from BigCommerce to Shopify while enhancing performance and simplifying management.</p>
          </div>
          <div class="bento-tile text-center">
            <FiDatabase className="text-3xl text-violet-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Magento to Shopify</h2>
            <p class="text-sm text-muted-foreground">Move from Magento to Shopify for a more user-friendly platform, faster performance, and better scalability.</p>
          </div>
          <div class="bento-tile text-center">
            <FiSettings className="text-3xl text-amber-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Third-Party Integrations</h2>
            <p class="text-sm text-muted-foreground">Connect your Shopify store with essential tools like CRMs, ERPs, and marketing platforms to streamline operations.</p>
          </div>
        </div>
      </div>
    </section>
    <FAQSection faqs={faqs} />
    <ServiceCTA />
  </div>
  <CTABottom />
</Layout>
