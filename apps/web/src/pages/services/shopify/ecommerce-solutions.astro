---
import Layout from "@/layouts/Layout.astro";
import CTABottom from "@/components/CTA.astro";
import ServiceCTA from "@/components/ServiceCTA";
import FAQSection from "@/components/FAQSection.astro";
import { createSEO } from "@/utils/seo";

const faqs = [
  { question: "What e-commerce platforms do you work with?", answer: "We specialize in Shopify and Shopify Plus, but also build on headless architectures using Next.js, Hydrogen, and custom solutions tailored to your business needs." },
  { question: "Can you build a custom e-commerce store from scratch?", answer: "Yes. We handle everything from design and development to payment gateway integration, shipping setup, and launch. Every store is built for performance and conversions." },
  { question: "How do you handle payment gateway integration?", answer: "We integrate with Shopify Payments, Stripe, PayPal, and other providers. We ensure PCI compliance and set up multi-currency support if needed." },
  { question: "Do you offer analytics and reporting setup?", answer: "Yes, we set up Google Analytics 4, conversion tracking, and custom dashboards so you can monitor sales, traffic, and customer behavior in real time." },
  { question: "Can you optimize an existing e-commerce store?", answer: "Absolutely. We audit your current store for performance bottlenecks, UX issues, and conversion opportunities, then implement data-driven improvements." },
];

const seo = createSEO({
  pageName: "E-commerce Solutions",
  description: "Complete e-commerce solutions to power your online business. From custom platform development and payment gateway integration to analytics-driven optimization, we build stores that convert.",
  keywords: "e-commerce solutions, online business, e-commerce platforms, online store development",
  image: "/images/services/ecommerce-solutions.jpg",
  contentType: "service",
  pathname: "/services/ecommerce-solutions"
});
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20">
            E-commerce
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4">E-commerce Solutions</h1>
          <p class="text-lg text-white/60 max-w-2xl mx-auto">
            Complete e-commerce solutions to power your online business with custom platforms, seamless integrations, and data-driven optimization.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-grid grid-cols-1 md:grid-cols-3">
          <div class="bento-tile md:col-span-2 text-center">
            <h2 class="text-xl font-semibold text-foreground mb-2">Platform Development</h2>
            <p class="text-sm text-muted-foreground">Custom e-commerce platforms built for your specific business needs.</p>
          </div>
          <div class="bento-tile text-center">
            <h2 class="text-xl font-semibold text-foreground mb-2">Integration Services</h2>
            <p class="text-sm text-muted-foreground">Seamless integration with payment gateways, shipping providers, and third-party services.</p>
          </div>
          <div class="bento-tile-accent text-center">
            <h2 class="text-xl font-semibold mb-2">Analytics & Optimization</h2>
            <p class="text-sm text-white/70">Data-driven optimization to improve conversion rates and customer experience.</p>
          </div>
        </div>
      </div>
    </section>
    <FAQSection faqs={faqs} />
    <ServiceCTA />
  </div>
  <CTABottom />
</Layout>
