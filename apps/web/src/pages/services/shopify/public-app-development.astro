---
import { FiCode, FiTool, FiCloud } from "react-icons/fi";
import CTABottom from "@/components/CTA.astro";
import Layout from "@/layouts/Layout.astro";
import ServiceCTA from "@/components/ServiceCTA";
import FAQSection from "@/components/FAQSection.astro";
import { createSEO } from "@/utils/seo";

const faqs = [
  { question: "What is a Shopify public app?", answer: "A public app is listed on the Shopify App Store and available to all Shopify merchants. It uses OAuth authentication and multi-tenant architecture to serve thousands of stores." },
  { question: "How do you handle Shopify App Store approval?", answer: "We build apps to meet all of Shopify's review requirements from the start, including Polaris UI compliance, proper OAuth flows, and webhook handling. We manage the full submission process." },
  { question: "What monetization options are available for public apps?", answer: "We implement Shopify's billing API for recurring subscriptions, one-time charges, and usage-based pricing. You can offer free plans with paid upgrades." },
  { question: "How do you ensure the app scales for many merchants?", answer: "We use multi-tenant database architecture, background job processing, rate limit handling, and deploy to scalable infrastructure like Cloudflare Workers." },
  { question: "Can you build both the app and the App Store listing?", answer: "Yes. We handle development, testing, App Store listing copy, screenshots, and the submission process. We also iterate on feedback from Shopify's review team." },
];

const seo = createSEO({
  pageName: "Public App Development",
  description: "Build scalable Shopify public apps designed for the App Store. From concept to launch, we develop high-quality apps that serve thousands of merchants and generate recurring revenue.",
  keywords: "public app development, shopify app development, shopify app store, e-commerce apps",
  image: "/images/services/public-app-development.jpg",
  contentType: "service",
  pathname: "/services/public-app-development"
});
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20">
            Shopify App Store
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4">Public App Development</h1>
          <p class="text-lg text-white/60 max-w-2xl mx-auto">
            Take your Shopify store to the next level with our expert app development services. Whether it's a custom app tailored to your business needs or a public app designed to serve thousands of merchants, we've got you covered.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-grid grid-cols-1 md:grid-cols-3">
          <div class="bento-tile md:col-span-2 text-center">
            <FiCode className="text-3xl text-primary-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Custom App Development</h2>
            <p class="text-sm text-muted-foreground">Build apps tailored to your specific requirements, integrating unique features that make your store stand out.</p>
          </div>
          <div class="bento-tile-accent text-center">
            <FiTool className="text-3xl text-white/80 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold mb-2">Public App Development</h2>
            <p class="text-sm text-white/70">Create scalable public apps that can be listed on the Shopify App Store to reach a global audience.</p>
          </div>
          <div class="bento-tile text-center">
            <FiCloud className="text-3xl text-violet-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Seamless Integrations</h2>
            <p class="text-sm text-muted-foreground">Integrate third-party tools and services seamlessly into your Shopify store for enhanced functionality.</p>
          </div>
        </div>
      </div>
    </section>
    <FAQSection faqs={faqs} />
    <ServiceCTA />
  </div>
  <CTABottom />
</Layout>
