---
import Layout from "@/layouts/Layout.astro";
import CTABottom from "@/components/CTA.astro";
import FAQSchema from "@/components/FAQSchema.astro";
import { createSEO } from "@/utils/seo";
import { siteConfig } from "@/config/site";
import {
  pseoServices,
  pseoCities,
  type PSEOService,
  type PSEOCity,
  buildTargetKeywords
} from "@/config/pseo";

interface Props {
  service: PSEOService;
  city: PSEOCity;
  uniqueValueProp: string;
}

export function getStaticPaths() {
  return pseoServices.flatMap((service, serviceIndex) =>
    pseoCities.map((city, cityIndex) => ({
      params: { service: service.slug, city: city.slug },
      props: {
        service,
        city,
        uniqueValueProp:
          service.uniqueValueProps[(serviceIndex + cityIndex) % service.uniqueValueProps.length]
      }
    }))
  );
}

const { service, city, uniqueValueProp } = Astro.props as Props;

const serviceBenefit = service.serviceBenefit;
const localChallenge = city.localChallenge;
const targetKeywords = buildTargetKeywords(service, city);
const keywords = targetKeywords.join(", ");

const seo = createSEO({
  pageName: `${service.name} in ${city.name}`,
  description: `${service.metaDescription} We help ${city.name} brands overcome ${localChallenge}.`,
  keywords,
  pathname: `/shopify/${service.slug}/${city.slug}`,
  contentType: "service"
});

seo.structuredData = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.name,
  description: seo.description,
  provider: {
    "@type": "Organization",
    name: siteConfig.name,
    url: siteConfig.url
  },
  serviceType: service.name,
  areaServed: {
    "@type": "City",
    name: city.name
  }
};

const faqs = [
  {
    question: `Why does ${service.name.toLowerCase()} matter for a ${city.name} store?`,
    answer: `Stores in ${city.name} run into ${localChallenge}. ${city.commerceStat} Getting the ${service.name.toLowerCase()} right is what gives you ${serviceBenefit}.`
  },
  {
    question: `What payment methods do ${city.name} shoppers expect?`,
    answer: `Most ${city.name} shoppers reach for ${city.paymentGateways.slice(0, 3).join(", ")}. We set up the gateways your customers actually use, so fewer people drop off at checkout.`
  },
  {
    question: `How long does ${service.name.toLowerCase()} take for a ${city.name} store?`,
    answer: `It depends on the scope. Smaller jobs take 1–2 weeks; bigger builds and migrations run 4–12 weeks. We'll give you a realistic timeline upfront, not a guess.`
  },
  {
    question: `What makes Capaxe different from other Shopify agencies serving ${city.name}?`,
    answer: `We're hands-on Shopify developers, not a sales team — and we pay attention to what works in ${city.name}. The focus is simple: ${uniqueValueProp}.`
  },
  {
    question: "How do I get started with Capaxe?",
    answer: `Just reach out for a free chat. We'll take a look at your current setup, talk through what you want to do in ${city.name}, and come back with a clear plan, timeline, and price.`
  },
];
---

<Layout seo={seo}>
  <!-- Hero -->
  <section class="pt-32 pb-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto space-y-6">
      <h1 class="text-4xl md:text-5xl font-bold">
        {service.name} for {city.name} Shopify Stores
      </h1>
      <p class="text-lg text-muted-foreground">
        If you run a Shopify store in {city.name}, you already know {localChallenge} can quietly cost
        you sales. We help {city.name} brands fix that with {service.name.toLowerCase()} that's built
        around how your customers actually shop — work that shows up as {serviceBenefit}.
      </p>
      <div class="flex flex-wrap gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-primary-500/10 text-primary-600 text-sm font-medium border border-primary-500/20">
          {city.currency} · {city.timezone.split("/")[1]?.replace(/_/g, " ")}
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-foreground/5 text-muted-foreground text-sm border border-foreground/10">
          Population: {city.population}
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-foreground/5 text-muted-foreground text-sm border border-foreground/10">
          Support hours: {city.supportHours}
        </span>
      </div>
    </div>
  </section>

  <!-- Market intelligence -->
  <section class="py-16 px-4 bg-foreground/5">
    <div class="max-w-5xl mx-auto space-y-8">
      <h2 class="text-3xl font-semibold">The {city.name} E-commerce Market</h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bento-tile space-y-3">
          <h3 class="text-lg font-semibold">Market Stat</h3>
          <p class="text-muted-foreground">{city.commerceStat}</p>
        </div>
        <div class="bento-tile space-y-3">
          <h3 class="text-lg font-semibold">Shopper Behaviour</h3>
          <p class="text-muted-foreground">{city.marketContext}</p>
        </div>
      </div>

      <div class="bento-tile space-y-4">
        <h3 class="text-lg font-semibold">Preferred Payment Methods in {city.name}</h3>
        <p class="text-sm text-muted-foreground">
          We set up whichever gateways your {city.name} customers prefer, so nobody bails at checkout just because their payment option is missing.
        </p>
        <div class="flex flex-wrap gap-2">
          {city.paymentGateways.map(gateway => (
            <span class="inline-block px-3 py-1 rounded-full bg-primary-500/10 text-primary-600 text-sm font-medium border border-primary-500/20">
              {gateway}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Why localised service matters -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto space-y-4">
      <h2 class="text-3xl font-semibold">Why a {city.name}-Specific Approach Helps</h2>
      <p class="text-lg text-muted-foreground">
        A store that converts well in one market can fall flat in another. Shoppers in {city.name} have
        their own habits — how they pay, what they trust, when they buy — and a store that ignores that
        leaves money on the table.
      </p>
      <p class="text-lg text-muted-foreground">
        We know Shopify well and we take the time to understand what works in {city.name}. Whether you
        need a full rebuild, a tricky app integration, or some focused performance work, the goal is the
        same: {uniqueValueProp}. No filler, just the changes that move the numbers.
      </p>
    </div>
  </section>

  <!-- Process -->
  <section class="py-16 px-4 bg-foreground/5">
    <div class="max-w-5xl mx-auto space-y-6">
      <h2 class="text-3xl font-semibold">How We Work</h2>
      <p class="text-lg text-muted-foreground">
        No surprises and no jargon. Here's what working with us on a {city.name} project looks like.
      </p>
      <ol class="space-y-6 list-decimal list-inside text-muted-foreground">
        <li class="space-y-2">
          <h3 class="text-2xl font-semibold text-foreground">We figure out what you actually need</h3>
          <p>
            First we look at your store, your goals, and who you're selling to in {city.name}. That way
            the {service.name.toLowerCase()} plan lines up with the results you care about — not a generic
            checklist.
          </p>
        </li>
        <li class="space-y-2">
          <h3 class="text-2xl font-semibold text-foreground">We build it and test it properly</h3>
          <p>
            Then we do the work: clean Liquid, no data left behind on migrations, and real speed gains on
            Core Web Vitals where that's the focus. Everything gets tested before it goes anywhere near
            your customers.
          </p>
        </li>
        <li class="space-y-2">
          <h3 class="text-2xl font-semibold text-foreground">We launch and stick around</h3>
          <p>
            Once it's tested, we handle the launch and keep an eye on things afterwards. You're not on
            your own — our team is here across {city.supportHours} if anything comes up.
          </p>
        </li>
      </ol>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto space-y-6">
      <h2 class="text-3xl font-semibold text-center">Frequently Asked Questions</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {faqs.map(faq => (
          <div class="bento-tile rounded-lg">
            <h3 class="text-base font-semibold mb-2">{faq.question}</h3>
            <p class="text-sm text-muted-foreground">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <FAQSchema faqs={faqs} />

  <!-- CTA -->
  <section class="py-16 px-4 bg-foreground/5">
    <div class="max-w-5xl mx-auto space-y-6 text-center">
      <h2 class="text-3xl font-semibold">Let's talk about your {city.name} store</h2>
      <p class="text-lg text-muted-foreground">
        Slow pages and clunky checkouts cost you sales every day. If that sounds familiar, we can help —
        tell us what's going on and we'll point you in the right direction, no pressure.
      </p>
      <a
        class="inline-flex items-center justify-center rounded-md bg-black px-6 py-3 text-white text-lg font-medium transition hover:bg-gray-800"
        href="/contact"
      >
        Contact us for a free consultation
      </a>
    </div>
  </section>

  <CTABottom />
</Layout>
