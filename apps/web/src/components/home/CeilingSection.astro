---
import { Layers, Code2, TrendingDown, Settings2 } from "lucide-react";

const symptoms = [
  { icon: Layers, label: "Installed the apps" },
  { icon: Settings2, label: "Redesigned the theme" },
  { icon: Code2, label: "A/B tested the hero" },
  { icon: TrendingDown, label: "Ran paid harder" },
];
---

<section class="relative section max-w-7xl mx-auto px-6 reveal-on-scroll">
  <!-- Decorative SVG -->
  <div
    class="absolute -top-10 left-0 right-0 h-px pointer-events-none"
    aria-hidden="true"
  >
    <div
      class="h-px bg-linear-to-r from-transparent via-border to-transparent"
    >
    </div>
  </div>

  <div class="bento-grid grid-cols-1 md:grid-cols-5">
    <!-- Heading + body (3 cols) -->
    <div class="bento-tile md:col-span-3 relative overflow-hidden">
      <div
        class="absolute -top-16 -right-16 w-64 h-64 pointer-events-none opacity-40"
        aria-hidden="true"
      >
        <svg viewBox="0 0 240 240" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern
              id="ceiling-dots"
              width="14"
              height="14"
              patternUnits="userSpaceOnUse"
            >
              <circle
                cx="1"
                cy="1"
                r="1"
                fill="currentColor"
                class="text-primary-400/40"></circle>
            </pattern>
          </defs>
          <rect width="240" height="240" fill="url(#ceiling-dots)"></rect>
        </svg>
      </div>

      <div class="relative z-10">
        <span
          class="inline-block text-[11px] font-bold uppercase tracking-[0.22em] text-primary mb-4"
        >
          The Ceiling
        </span>
        <h2
          class="text-balance text-3xl md:text-4xl lg:text-5xl font-bold text-foreground leading-[1.1] tracking-tight mb-6"
        >
          Most Shopify stores don't have a design problem.
          <span class="text-muted-foreground">
            They have a systems problem.
          </span>
        </h2>
        <p class="text-base md:text-lg text-muted-foreground leading-relaxed">
          You've installed the apps. You've redesigned the theme. You've A/B
          tested the hero, tightened the cart, run paid harder.
          <span class="font-semibold text-foreground"
            >Revenue still flattens.</span
          >
        </p>
        <p
          class="text-base md:text-lg text-muted-foreground leading-relaxed mt-4"
        >
          That's because the next stage of growth isn't a styling decision —
          it's an engineering one. It lives in how products are ranked, how
          pages hold up under real traffic, how merchandising responds to buyer
          behavior, how the checkout adapts to your customer.
        </p>
        <p
          class="text-base md:text-lg text-foreground font-semibold leading-relaxed mt-6"
        >
          These are systems. They don't come pre-installed.
        </p>
      </div>
    </div>

    <!-- Symptoms checklist (2 cols) -->
    <div
      class="bento-tile md:col-span-2 flex flex-col justify-between relative overflow-hidden"
    >
      <div>
        <span
          class="text-[11px] font-bold uppercase tracking-[0.18em] text-muted-foreground"
        >
          You've already tried
        </span>
        <ul class="mt-6 space-y-4">
          {
            symptoms.map(({ icon: Icon, label }) => (
              <li class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-muted text-muted-foreground line-through decoration-primary/60 decoration-2">
                  <Icon className="w-4 h-4" />
                </span>
                <span class="text-sm text-muted-foreground line-through decoration-primary/40">
                  {label}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="mt-8 pt-6 border-t border-border">
        <p class="text-sm text-foreground font-semibold">Still flat?</p>
        <p class="text-sm text-muted-foreground mt-1">
          The ceiling isn't the design. It's the engineering underneath.
        </p>
      </div>
    </div>
  </div>
</section>
