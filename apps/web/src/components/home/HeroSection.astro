---
import { Zap, ShoppingBag, Activity, Wrench } from "lucide-react";
import BookingButton from "@/components/BookingButton";
import AuditModal from "@/components/AuditModal";

const systems = [
  { label: "Conversion", icon: Activity },
  { label: "Merchandising", icon: ShoppingBag },
  { label: "Performance", icon: Zap },
  { label: "Custom Engineering", icon: Wrench },
];
---

<section
  class="relative flex items-center pt-28 pb-12 overflow-hidden"
  style="min-height: clamp(560px, 78vh, 880px)"
>
  <!-- Ambient background SVG -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <svg
      class="absolute inset-0 w-full h-full"
      preserveAspectRatio="xMidYMid slice"
      viewBox="0 0 1600 900"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <pattern
          id="hero-dots"
          x="0"
          y="0"
          width="32"
          height="32"
          patternUnits="userSpaceOnUse"
        >
          <circle
            cx="1.5"
            cy="1.5"
            r="1.5"
            fill="currentColor"
            class="text-foreground/10"></circle>
        </pattern>
        <radialGradient id="hero-glow-a" cx="20%" cy="30%" r="50%">
          <stop
            offset="0%"
            stop-color="currentColor"
            class="text-primary-400"
            stop-opacity="0.18"></stop>
          <stop
            offset="100%"
            stop-color="currentColor"
            class="text-primary-400"
            stop-opacity="0"></stop>
        </radialGradient>
        <radialGradient id="hero-glow-b" cx="85%" cy="80%" r="40%">
          <stop
            offset="0%"
            stop-color="currentColor"
            class="text-primary-500"
            stop-opacity="0.12"></stop>
          <stop
            offset="100%"
            stop-color="currentColor"
            class="text-primary-500"
            stop-opacity="0"></stop>
        </radialGradient>
      </defs>
      <rect width="1600" height="900" fill="url(#hero-dots)"></rect>
      <rect width="1600" height="900" fill="url(#hero-glow-a)"></rect>
      <rect width="1600" height="900" fill="url(#hero-glow-b)"></rect>
      <!-- Flowing accent lines -->
      <path
        d="M -100 720 Q 400 580 800 680 T 1700 600"
        stroke="currentColor"
        stroke-width="1"
        fill="none"
        class="text-primary-400/20"></path>
      <path
        d="M -100 800 Q 500 700 1000 780 T 1700 720"
        stroke="currentColor"
        stroke-width="1"
        fill="none"
        class="text-primary-400/15"></path>
    </svg>
  </div>

  <div class="container max-w-7xl mx-auto px-6 relative z-10">
    <div class="bento-grid grid-cols-1 md:grid-cols-4 md:grid-rows-2">
      <!-- Main Hero Tile -->
      <div
        class="bento-tile-accent md:col-span-3 md:row-span-2 flex flex-col justify-between relative overflow-hidden"
      >
        <!-- Inner SVG decoration -->
        <div
          class="absolute inset-0 pointer-events-none opacity-[0.07]"
          aria-hidden="true"
        >
          <svg
            class="w-full h-full"
            viewBox="0 0 800 600"
            preserveAspectRatio="xMidYMid slice"
            xmlns="http://www.w3.org/2000/svg"
          >
            <defs>
              <pattern
                id="hero-inner-grid"
                width="40"
                height="40"
                patternUnits="userSpaceOnUse"
              >
                <path
                  d="M 40 0 L 0 0 0 40"
                  fill="none"
                  stroke="white"
                  stroke-width="1"></path>
              </pattern>
            </defs>
            <rect width="800" height="600" fill="url(#hero-inner-grid)"></rect>
          </svg>
        </div>

        <!-- Floating geometric accent -->
        <div
          class="absolute -bottom-32 -right-32 w-[420px] h-[420px] pointer-events-none"
          aria-hidden="true"
        >
          <svg
            class="w-full h-full hero-float-slow"
            viewBox="0 0 420 420"
            xmlns="http://www.w3.org/2000/svg"
          >
            <circle
              cx="210"
              cy="210"
              r="200"
              fill="none"
              stroke="white"
              stroke-opacity="0.08"
              stroke-width="1"></circle>
            <circle
              cx="210"
              cy="210"
              r="140"
              fill="none"
              stroke="white"
              stroke-opacity="0.1"
              stroke-width="1"></circle>
            <circle cx="210" cy="210" r="80" fill="white" fill-opacity="0.04"
            ></circle>
            <circle cx="210" cy="210" r="6" fill="white" fill-opacity="0.5"
            ></circle>
          </svg>
        </div>

        <div class="relative z-10">
          <div class="flex items-center gap-2 mb-8 hero-animate">
            <span class="w-8 h-px bg-white/40"></span>
            <span
              class="text-[11px] font-bold uppercase tracking-[0.22em] text-white/70"
            >
              Shopify Systems Engineering
            </span>
          </div>
          <h1
            class="text-balance text-4xl md:text-5xl lg:text-[3.75rem] font-bold leading-[1.05] tracking-tight mb-6 hero-animate hero-animate-delay-1"
          >
            For Shopify brands that have outgrown themes, apps,
            <span class="text-white/70">and quick&nbsp;fixes.</span>
          </h1>
          <p
            class="text-balance text-lg md:text-xl text-white/75 max-w-2xl leading-relaxed hero-animate hero-animate-delay-2"
          >
            We engineer the systems that unlock your next stage of growth —
            conversion, merchandising, and performance that off-the-shelf
            Shopify can't deliver.
          </p>
        </div>

        <div
          class="flex flex-col sm:flex-row gap-3 mt-10 relative z-10 hero-animate hero-animate-delay-4"
        >
          <BookingButton
            client:load
            className="bg-primary-500 text-white border-primary-500 hover:bg-primary-600 hover:border-primary-600 font-semibold rounded-xl btn-shimmer"
          >
            Book a strategy call
          </BookingButton>
          <AuditModal
            client:load
            className="bg-white/15 backdrop-blur-sm text-white px-6 py-3 rounded-xl font-medium hover:bg-white/25 transition-all duration-200 border border-white/20"
          >
            Request a teardown
          </AuditModal>
        </div>
      </div>

      <!-- Four Systems Tile -->
      <div
        class="bento-tile flex flex-col justify-between relative overflow-hidden group"
        style="opacity: 0; animation: fade-up 0.6s ease-out 0.35s forwards;"
      >
        <div class="flex items-center justify-between">
          <span
            class="text-[11px] font-bold uppercase tracking-[0.18em] text-muted-foreground"
          >
            Four systems
          </span>
          <span class="text-[10px] text-muted-foreground/60">01–04</span>
        </div>
        <ul class="mt-5 space-y-3">
          {
            systems.map(({ label, icon: Icon }, i) => (
              <li class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg bg-primary-500/10 text-primary-400 group-hover:bg-primary-500/20 transition-colors">
                  <Icon className="w-3.5 h-3.5" />
                </span>
                <span class="text-sm font-semibold text-foreground">
                  {label}
                </span>
                <span class="ml-auto text-[10px] font-mono text-muted-foreground/40">
                  0{i + 1}
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Engineering Depth Tile -->
      <div
        class="bento-tile flex flex-col justify-between relative overflow-hidden"
        style="opacity: 0; animation: fade-up 0.6s ease-out 0.5s forwards;"
      >
        <div
          class="absolute -top-10 -right-10 w-40 h-40 pointer-events-none opacity-30"
          aria-hidden="true"
        >
          <svg viewBox="0 0 160 160" xmlns="http://www.w3.org/2000/svg">
            <circle
              cx="80"
              cy="80"
              r="60"
              fill="none"
              stroke="currentColor"
              class="text-primary-400/30"
              stroke-width="1"></circle>
            <circle
              cx="80"
              cy="80"
              r="40"
              fill="none"
              stroke="currentColor"
              class="text-primary-400/20"
              stroke-width="1"></circle>
          </svg>
        </div>
        <div class="relative z-10">
          <span
            class="text-[11px] font-bold uppercase tracking-[0.18em] text-muted-foreground"
          >
            Built by engineers
          </span>
          <p class="text-sm text-muted-foreground leading-relaxed mt-4">
            Shipping commerce systems for considered DTC, fashion, and lifestyle
            brands — backed by years of scaling production systems, including
            financial products at
            <span class="font-semibold text-foreground">Paytm</span>.
          </p>
        </div>
        <div
          class="flex items-center gap-2 mt-5 pt-4 border-t border-border/60 relative z-10"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"
          ></span>
          <span class="text-[11px] font-medium text-muted-foreground">
            We take on a small number of brands at a time
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes hero-float-slow {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(6deg);
    }
  }
  .hero-float-slow {
    animation: hero-float-slow 14s ease-in-out infinite;
    transform-origin: center;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-float-slow {
      animation: none;
    }
  }
</style>
