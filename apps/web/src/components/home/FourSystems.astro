---
import { Activity, ShoppingBag, Zap, Wrench, ArrowRight } from "lucide-react";

const systems = [
  {
    number: "01",
    icon: Activity,
    title: "Conversion System",
    body: "We treat conversion as a product, not a project. We trace where revenue is leaking — landing, PDP, cart, checkout — and rebuild friction points with native Shopify primitives, not duct-taped apps.",
    surfaces: ["Landing", "PDP", "Cart", "Checkout"],
    href: "/capabilities#conversion",
  },
  {
    number: "02",
    icon: ShoppingBag,
    title: "Merchandising System",
    body: "Out-of-the-box collection sorting is the silent killer of AOV. We engineer ranking, filtering, and discovery logic that surfaces the right product to the right buyer — across collections, search, and recommendations.",
    surfaces: ["Ranking", "Search", "Filtering", "Discovery"],
    href: "/capabilities#merchandising",
  },
  {
    number: "03",
    icon: Zap,
    title: "Performance System",
    body: "Speed is a revenue lever, not a Lighthouse score. We rebuild Core Web Vitals from the theme up, eliminate the app-script tax, and engineer stability for sale-day traffic.",
    surfaces: ["Core Web Vitals", "App-script tax", "Sale-day stability"],
    href: "/capabilities#performance",
  },
  {
    number: "04",
    icon: Wrench,
    title: "Custom Engineering",
    body: "When apps fall short, we go deeper. Shopify Functions, theme app extensions, Hydrogen storefronts, custom backends, ERP and OMS integrations — built once, owned forever.",
    surfaces: ["Functions", "Hydrogen", "Integrations", "Backends"],
    href: "/capabilities#custom",
  },
];
---

<section class="section max-w-7xl mx-auto px-6 reveal-on-scroll">
  <div class="max-w-3xl mb-12">
    <span
      class="inline-block text-[11px] font-bold uppercase tracking-[0.22em] text-primary mb-4"
    >
      Capabilities
    </span>
    <h2
      class="text-balance text-3xl md:text-4xl lg:text-5xl font-bold text-foreground leading-[1.1] tracking-tight"
    >
      Four systems behind every brand we work with.
    </h2>
    <p
      class="text-base md:text-lg text-muted-foreground leading-relaxed mt-6"
    >
      We don't sell services. We engineer the systems that actually compound
      revenue — owned forever, not rented from the app store.
    </p>
  </div>

  <div class="bento-grid grid-cols-1 md:grid-cols-2">
    {
      systems.map(({ number, icon: Icon, title, body, surfaces, href }, i) => (
        <a
          href={href}
          class={`bento-tile group relative overflow-hidden flex flex-col justify-between min-h-72 ${i % 3 === 0 ? "md:col-span-1" : ""}`}
        >
          <div
            class="absolute -top-10 -right-10 w-44 h-44 pointer-events-none opacity-50"
            aria-hidden="true"
          >
            <svg viewBox="0 0 180 180" xmlns="http://www.w3.org/2000/svg">
              <circle
                cx="90"
                cy="90"
                r="80"
                fill="none"
                stroke="currentColor"
                class="text-primary-400/15"
                stroke-width="1"
              />
              <circle
                cx="90"
                cy="90"
                r="50"
                fill="none"
                stroke="currentColor"
                class="text-primary-400/20"
                stroke-width="1"
              />
            </svg>
          </div>

          <div class="relative z-10">
            <div class="flex items-center justify-between mb-6">
              <span class="inline-flex items-center justify-center w-11 h-11 rounded-xl bg-primary-500/10 text-primary-400 group-hover:bg-primary-500/20 group-hover:scale-110 transition-all duration-300">
                <Icon className="w-5 h-5" />
              </span>
              <span class="text-[10px] font-mono text-muted-foreground/50 tracking-widest">
                {number}
              </span>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-foreground group-hover:text-primary-300 transition-colors mb-3">
              {title}
            </h3>
            <p class="text-sm md:text-base text-muted-foreground leading-relaxed">
              {body}
            </p>
          </div>

          <div class="relative z-10 mt-6 pt-5 border-t border-border/60 flex items-center justify-between gap-4 flex-wrap">
            <div class="flex flex-wrap gap-1.5">
              {surfaces.map((s) => (
                <span class="text-[10px] font-medium uppercase tracking-wider text-muted-foreground/80 px-2 py-1 rounded-md bg-muted/60">
                  {s}
                </span>
              ))}
            </div>
            <span class="inline-flex items-center gap-1 text-xs font-semibold text-primary group-hover:gap-2 transition-all">
              Explore
              <ArrowRight className="w-3.5 h-3.5" />
            </span>
          </div>
        </a>
      ))
    }
  </div>
</section>
