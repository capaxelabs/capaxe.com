---
const products = [
  {
    name: "RankFlo",
    note: "SKU & SEO intelligence for Shopify",
  },
  {
    name: "Opskitty",
    note: "Web operations platform",
  },
];

const credentials = [
  {
    label: "Paytm Money",
    note: "Financial products at scale",
  },
  {
    label: "10+ years",
    note: "Shipping production systems",
  },
];
---

<section
  class="relative section max-w-7xl mx-auto px-6 reveal-on-scroll overflow-hidden"
>
  <div class="bento-grid grid-cols-1 md:grid-cols-5">
    <!-- Founder body -->
    <div
      class="bento-tile-accent md:col-span-3 relative overflow-hidden flex flex-col justify-between"
    >
      <!-- Decorative SVG -->
      <div
        class="absolute -bottom-20 -right-20 w-80 h-80 pointer-events-none opacity-20"
        aria-hidden="true"
      >
        <svg viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern
              id="founder-lines"
              width="20"
              height="20"
              patternUnits="userSpaceOnUse"
              patternTransform="rotate(45)"
            >
              <line x1="0" y1="0" x2="0" y2="20" stroke="white" stroke-width="1"></line>
            </pattern>
          </defs>
          <circle cx="160" cy="160" r="140" fill="url(#founder-lines)"></circle>
        </svg>
      </div>

      <div class="relative z-10">
        <span
          class="inline-block text-[11px] font-bold uppercase tracking-[0.22em] text-white/70 mb-4"
        >
          Founder
        </span>
        <h2
          class="text-balance text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-[1.1] tracking-tight mb-6"
        >
          Engineering depth, not agency theatrics.
        </h2>
        <p class="text-base md:text-lg text-white/80 leading-relaxed">
          Capaxe is led by engineers with over a decade of shipping production
          systems — including financial products at
          <span class="font-semibold text-white">Paytm Money</span> serving
          millions of users, and SaaS tools currently powering Shopify brands
          (<span class="font-semibold text-white">RankFlo</span> for SKU and
          SEO intelligence, <span class="font-semibold text-white">Opskitty</span>
          for web operations).
        </p>
        <p class="text-base md:text-lg text-white/80 leading-relaxed mt-4">
          We bring the same engineering discipline to commerce we brought to
          scaling fintech: instrumented, accountable, built to last.
        </p>
      </div>

      <div
        class="mt-8 pt-6 border-t border-white/15 relative z-10 flex items-center gap-3"
      >
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        <p class="text-sm text-white/90 font-medium">
          You won't get an account manager. You'll get the people doing the work.
        </p>
      </div>
    </div>

    <!-- Right column: split into two tiles -->
    <div class="md:col-span-2 grid grid-cols-1 gap-4 md:gap-6">
      <!-- Products we operate -->
      <div class="bento-tile relative overflow-hidden">
        <span
          class="text-[11px] font-bold uppercase tracking-[0.18em] text-muted-foreground"
        >
          Products we operate
        </span>
        <ul class="mt-5 space-y-4">
          {
            products.map(({ name, note }) => (
              <li class="flex items-start gap-3">
                <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-primary-500/10 text-primary-400 font-bold text-sm ring-1 ring-primary-500/20">
                  {name.charAt(0)}
                </span>
                <div class="flex-1 min-w-0">
                  <div class="text-sm font-bold text-foreground">{name}</div>
                  <div class="text-xs text-muted-foreground mt-0.5">{note}</div>
                </div>
              </li>
            ))
          }
        </ul>
        <p class="text-xs text-muted-foreground/80 mt-5 pt-4 border-t border-border italic">
          Products that keep us close to where Shopify is actually breaking.
        </p>
      </div>

      <!-- Credentials -->
      <div class="bento-tile relative overflow-hidden bg-muted/30">
        <span
          class="text-[11px] font-bold uppercase tracking-[0.18em] text-muted-foreground"
        >
          Engineering pedigree
        </span>
        <div class="grid grid-cols-2 gap-4 mt-5">
          {
            credentials.map(({ label, note }) => (
              <div>
                <div class="text-lg md:text-xl font-bold text-foreground">
                  {label}
                </div>
                <div class="text-[11px] text-muted-foreground mt-0.5 leading-tight">
                  {note}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
