---
import { Search, ListOrdered, Hammer, TrendingUp } from "lucide-react";

const steps = [
  {
    number: "01",
    icon: Search,
    title: "Diagnose",
    body: "A structured review of your store — not a generic audit. We trace conversion, performance, and merchandising back to root cause.",
  },
  {
    number: "02",
    icon: ListOrdered,
    title: "Prioritize",
    body: "We rank opportunities by revenue impact, not by how easy they are to demo. You see the trade-offs.",
  },
  {
    number: "03",
    icon: Hammer,
    title: "Engineer",
    body: "We build, ship, measure. No theme-shopping, no plugin stacking.",
  },
  {
    number: "04",
    icon: TrendingUp,
    title: "Compound",
    body: "The best stores don't get rebuilt every year — they compound. We stay on as the engineering layer behind the brand.",
  },
];
---

<section
  class="relative section max-w-7xl mx-auto px-6 reveal-on-scroll overflow-hidden"
>
  <div class="max-w-3xl mb-12">
    <span
      class="inline-block text-[11px] font-bold uppercase tracking-[0.22em] text-primary mb-4"
    >
      How We Work
    </span>
    <h2
      class="text-balance text-3xl md:text-4xl lg:text-5xl font-bold text-foreground leading-[1.1] tracking-tight"
    >
      A different approach for brands past the template stage.
    </h2>
  </div>

  <div class="relative">
    <!-- Connecting line SVG (desktop only) -->
    <div
      class="hidden lg:block absolute top-12 left-[12.5%] right-[12.5%] h-px pointer-events-none"
      aria-hidden="true"
    >
      <svg
        class="w-full h-12"
        viewBox="0 0 1200 48"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M 0 24 L 1200 24"
          stroke="currentColor"
          class="text-border"
          stroke-width="1"
          stroke-dasharray="4 4"></path>
      </svg>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      {
        steps.map(({ number, icon: Icon, title, body }) => (
          <div class="bento-tile relative overflow-hidden">
            <div class="flex items-center justify-between mb-5">
              <span class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-primary-500/10 text-primary-400 ring-1 ring-primary-500/20">
                <Icon className="w-5 h-5" />
              </span>
              <span class="text-3xl font-black text-muted-foreground/10 tracking-tight">
                {number}
              </span>
            </div>
            <h3 class="text-lg md:text-xl font-bold text-foreground mb-2">
              {title}
            </h3>
            <p class="text-sm text-muted-foreground leading-relaxed">{body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
