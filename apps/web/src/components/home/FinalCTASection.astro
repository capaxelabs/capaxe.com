---
import { ArrowRight } from "lucide-react";
import { Button } from "@/components/ui/button";
import AuditModal from "@/components/AuditModal";
---

<section class="section max-w-7xl mx-auto px-6 reveal-on-scroll">
  <div
    class="bento-tile-accent relative overflow-hidden text-center py-16 md:py-20 px-6"
  >
    <!-- Background SVG -->
    <div
      class="absolute inset-0 pointer-events-none opacity-[0.08]"
      aria-hidden="true"
    >
      <svg
        class="w-full h-full"
        viewBox="0 0 1200 400"
        preserveAspectRatio="xMidYMid slice"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <pattern
            id="final-grid"
            width="60"
            height="60"
            patternUnits="userSpaceOnUse"
          >
            <path
              d="M 60 0 L 0 0 0 60"
              fill="none"
              stroke="white"
              stroke-width="1"></path>
          </pattern>
        </defs>
        <rect width="1200" height="400" fill="url(#final-grid)"></rect>
      </svg>
    </div>

    <!-- Floating accents -->
    <div
      class="absolute -top-20 -left-20 w-64 h-64 pointer-events-none"
      aria-hidden="true"
    >
      <svg viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg">
        <circle
          cx="128"
          cy="128"
          r="120"
          fill="none"
          stroke="white"
          stroke-opacity="0.08"
          stroke-width="1"></circle>
        <circle
          cx="128"
          cy="128"
          r="80"
          fill="none"
          stroke="white"
          stroke-opacity="0.1"
          stroke-width="1"></circle>
      </svg>
    </div>
    <div
      class="absolute -bottom-16 -right-16 w-56 h-56 pointer-events-none"
      aria-hidden="true"
    >
      <svg viewBox="0 0 224 224" xmlns="http://www.w3.org/2000/svg">
        <circle
          cx="112"
          cy="112"
          r="100"
          fill="none"
          stroke="white"
          stroke-opacity="0.06"
          stroke-width="1"></circle>
        <circle
          cx="112"
          cy="112"
          r="60"
          fill="white"
          fill-opacity="0.04"></circle>
      </svg>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto">
      <span
        class="inline-block text-[11px] font-bold uppercase tracking-[0.22em] text-white/70 mb-4"
      >
        Let's Engineer What's Next
      </span>
      <h2
        class="text-balance text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-[1.1] tracking-tight mb-6"
      >
        Past the plateau? Let's engineer what's next.
      </h2>
      <p
        class="text-base md:text-lg text-white/80 leading-relaxed mb-10 max-w-xl mx-auto"
      >
        We take on a small number of brands at a time. If your store has
        outgrown its current setup, start with a conversation.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/consultation">
          <Button
            size="lg"
            className="bg-white text-primary-600 hover:bg-gray-100 font-semibold rounded-xl btn-shimmer"
          >
            Book a strategy call
            <ArrowRight className="ml-2 h-4 w-4" />
          </Button>
        </a>
        <AuditModal
          client:load
          className="bg-white/15 backdrop-blur-sm text-white px-6 py-3 rounded-xl font-medium hover:bg-white/25 transition-all duration-200 border border-white/20"
        >
          Request a teardown
        </AuditModal>
      </div>
    </div>
  </div>
</section>
