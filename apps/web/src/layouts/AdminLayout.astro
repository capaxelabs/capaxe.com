---
import "@/styles/global.css";

interface Props {
  title: string;
  active?: "dashboard" | "leads" | "apps" | "themes" | "judgeme";
}
const { title, active = "dashboard" } = Astro.props;

const nav = [
  { key: "dashboard", label: "Dashboard", href: "/admin" },
  { key: "leads",     label: "Leads",     href: "/admin/leads" },
  { key: "apps",      label: "Apps",      href: "/admin/apps" },
  { key: "themes",    label: "Themes",    href: "/admin/themes" },
  { key: "judgeme",   label: "Judge.me",  href: "/admin/judgeme" },
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title} — Capaxe Admin</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-56 shrink-0 border-r border-slate-200 bg-white">
        <div class="px-5 py-4 border-b border-slate-200">
          <a href="/admin" class="block text-sm font-semibold tracking-tight">Capaxe Admin</a>
          <p class="mt-0.5 text-[11px] uppercase tracking-wider text-slate-500">Shopify leads</p>
        </div>
        <nav class="px-2 py-3">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "block rounded-md px-3 py-1.5 text-sm transition-colors",
                  active === item.key
                    ? "bg-slate-900 text-white"
                    : "text-slate-700 hover:bg-slate-100",
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <div class="absolute bottom-3 left-3 right-3 w-50">
          <form method="POST" action="/api/admin/logout">
            <button
              type="submit"
              class="w-full rounded-md border border-slate-200 bg-white px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-100"
            >
              Sign out
            </button>
          </form>
        </div>
      </aside>

      <!-- Main -->
      <main class="flex-1">
        <header class="border-b border-slate-200 bg-white">
          <div class="mx-auto max-w-7xl px-6 py-4">
            <h1 class="text-lg font-semibold tracking-tight">{title}</h1>
          </div>
        </header>
        <div class="mx-auto max-w-7xl px-6 py-6">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
