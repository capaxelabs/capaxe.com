---
import Layout from "@/layouts/Layout.astro";
import CTABottom from "@/components/CTA.astro";
import FAQSection from "@/components/FAQSection.astro";
import { createSEO } from "@/utils/seo";
import { getFAQPageSchema } from "@/lib/schemas";

const faqs = [
  { question: "What if I don't use all my retainer hours in a month?", answer: "Most retainer plans include a reasonable rollover window. But even unused hours aren't wasted — your team stays familiar with your codebase and ready to jump in instantly when needed." },
  { question: "Is a retainer worth it if I only need occasional updates?", answer: "Even stores with light development needs benefit from proactive monitoring, security patches, and performance optimization. A basic retainer covers all of this and prevents small issues from becoming expensive emergencies." },
  { question: "Can I switch from hourly billing to a retainer mid-project?", answer: "Yes. Many of our clients start with a project engagement and transition to a retainer once they see the value of ongoing support. We make the switch seamless." },
  { question: "How does retainer pricing compare to hiring a full-time Shopify developer?", answer: "A full-time Shopify developer costs $80K-$150K/year in salary alone, plus benefits, tools, and management overhead. A retainer gives you access to an entire agency team for a fraction of that cost." },
  { question: "What's the minimum commitment for a retainer plan?", answer: "We offer month-to-month retainers with no long-term lock-in. Most clients stay because the value is clear, not because they're contractually obligated." },
];

const seo = createSEO({
  pageName: "Shopify Retainer vs Hourly vs Project-Based — Pricing Comparison",
  description: "Compare Shopify retainer plans against hourly and project-based billing. See why retainers save money, reduce risk, and deliver better results for growing Shopify stores.",
  keywords: "shopify retainer vs hourly, shopify development pricing comparison, shopify retainer plan cost, shopify agency billing models, shopify project vs retainer",
  contentType: "basic",
  pathname: "/shopify-retainer-vs-hourly-vs-project",
});
seo.structuredData = getFAQPageSchema(faqs);

const comparisonRows = [
  { feature: "Monthly Cost", retainer: "$2,000 - $5,000/mo", hourly: "$3,000 - $8,000+/mo", project: "$5,000 - $50,000 per project", retainerWin: true },
  { feature: "Cost Predictability", retainer: "Fixed monthly fee", hourly: "Varies every month", project: "Fixed per project, but scope creep adds cost", retainerWin: true },
  { feature: "Response Time", retainer: "Same-day (SLA-backed)", hourly: "1-3 days (when available)", project: "Only during active project", retainerWin: true },
  { feature: "Team Familiarity with Your Store", retainer: "Deep — ongoing relationship", hourly: "Shallow — re-learns each time", project: "Temporary — ends with project", retainerWin: true },
  { feature: "Bug Fixes & Emergencies", retainer: "Included in plan", hourly: "$150-250/hr rush rate", project: "Not covered unless scoped", retainerWin: true },
  { feature: "Proactive Optimization", retainer: "Monthly speed, SEO & CRO checks", hourly: "Only if you request (and pay)", project: "Not included", retainerWin: true },
  { feature: "Security Monitoring", retainer: "Continuous monitoring included", hourly: "Pay per audit", project: "One-time audit at best", retainerWin: true },
  { feature: "Strategic Guidance", retainer: "Ongoing roadmap planning", hourly: "Ad-hoc advice when billing", project: "Scoped recommendations only", retainerWin: true },
  { feature: "Scaling for Peak Seasons", retainer: "Pre-planned, stress-free", hourly: "Scramble to book hours", project: "Requires new project scope", retainerWin: true },
  { feature: "App & Theme Updates", retainer: "Managed proactively", hourly: "Reactive — after things break", project: "Not covered", retainerWin: true },
  { feature: "Communication", retainer: "Dedicated Slack/channel + weekly syncs", hourly: "Email threads, variable response", project: "Project manager during engagement", retainerWin: true },
  { feature: "Long-Term ROI", retainer: "Highest — compounds over time", hourly: "Moderate — pay more as needs grow", project: "One-time value, no continuity", retainerWin: true },
];

const scenarios = [
  {
    title: "The 2 AM Checkout Disaster",
    description: "Your checkout breaks on a Friday night during a flash sale. Hourly developers aren't available until Monday. Project-scoped agencies say it's out of scope.",
    retainer: "Your retainer team gets an alert, diagnoses the issue within the hour, and pushes a fix before most customers even notice.",
    hourly: "You email your freelancer. They respond Monday morning. You've lost an entire weekend of sales.",
    project: "Your project ended 3 months ago. The agency quotes a new engagement with a 2-week lead time.",
    lost: "$15,000 - $50,000+ in lost weekend revenue",
  },
  {
    title: "BFCM Traffic Surge Preparation",
    description: "Black Friday is 6 weeks away. Your store needs load testing, speed optimization, and checkout flow improvements.",
    retainer: "Your team has been optimizing all quarter. Load tests are done. Checkout is already streamlined. You're ready.",
    hourly: "You scramble to book enough hours. The developer needs to re-learn your codebase first. Timeline is tight.",
    project: "You scope a rush project at 2x premium pricing. Delivery is uncertain with the compressed timeline.",
    lost: "$5,000 - $20,000 in rush fees and lost optimization time",
  },
  {
    title: "Shopify Theme Update Breaks Your Customizations",
    description: "Shopify releases a major theme update. Your custom sections, metafield integrations, and checkout tweaks stop working.",
    retainer: "Your team tests the update in staging first, identifies conflicts, and deploys a clean migration — zero downtime.",
    hourly: "You find out when customers report broken pages. You book emergency hours at rush rates.",
    project: "You submit a new project request. The agency can start in 3 weeks.",
    lost: "$3,000 - $10,000 in emergency fixes + conversion loss during downtime",
  },
  {
    title: "Competitor Launches a New Feature",
    description: "Your biggest competitor adds a product configurator. Your CEO wants the same thing yesterday.",
    retainer: "Your team scopes it in your weekly sync, starts building within days using their deep knowledge of your codebase.",
    hourly: "You get quotes from 3 freelancers. Fastest estimate: 4 weeks to start, after onboarding.",
    project: "You negotiate a new SOW. Kickoff is 2-3 weeks out after contracts and deposits.",
    lost: "Weeks of competitive advantage and market positioning",
  },
];

const costBreakdown = {
  retainer: { monthly: 3500, annual: 42000, extras: 0, emergencies: 0, total: 42000 },
  hourly: { monthly: 3000, annual: 36000, extras: 6000, emergencies: 8000, total: 50000 },
  project: { monthly: 0, annual: 45000, extras: 10000, emergencies: 12000, total: 67000 },
};
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <!-- Hero -->
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20">
            Pricing Comparison
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4">
            Retainer vs Hourly vs Project-Based
          </h1>
          <p class="text-lg text-white/60 max-w-3xl mx-auto">
            Not all billing models are equal. See why Shopify merchants who switch to retainers
            spend less, ship faster, and sleep better at night.
          </p>
        </div>
      </div>
    </section>

    <!-- Verdict Banner -->
    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile border-2 border-primary-500/30 p-8 text-center">
          <p class="text-sm font-semibold text-primary-400 uppercase tracking-wider mb-2">The Bottom Line</p>
          <p class="text-2xl md:text-3xl font-bold text-foreground mb-3">
            Retainer clients save 20-40% annually
          </p>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            compared to hourly billing, while getting faster response times, proactive optimization,
            and a team that actually knows their store inside out.
          </p>
        </div>
      </div>
    </section>

    <!-- Feature Comparison Table -->
    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold mb-8 text-foreground text-center">Feature-by-Feature Comparison</h2>
        <div class="bento-tile overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border">
                <th class="text-left py-4 px-4 text-muted-foreground font-medium w-1/4">Feature</th>
                <th class="text-left py-4 px-4 font-semibold text-primary-400 w-1/4">
                  Retainer
                  <span class="ml-2 inline-block px-2 py-0.5 rounded-full bg-primary-500/10 text-primary-400 text-xs">Recommended</span>
                </th>
                <th class="text-left py-4 px-4 text-muted-foreground font-medium w-1/4">Hourly</th>
                <th class="text-left py-4 px-4 text-muted-foreground font-medium w-1/4">Project-Based</th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row) => (
                <tr class="border-b border-border/50 hover:bg-muted/30 transition-colors">
                  <td class="py-4 px-4 font-medium text-foreground">{row.feature}</td>
                  <td class="py-4 px-4 text-primary-400 font-medium">{row.retainer}</td>
                  <td class="py-4 px-4 text-muted-foreground">{row.hourly}</td>
                  <td class="py-4 px-4 text-muted-foreground">{row.project}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Annual Cost Breakdown -->
    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold mb-8 text-foreground text-center">Real-World Annual Cost Comparison</h2>
        <p class="text-center text-muted-foreground mb-8 max-w-2xl mx-auto">
          For a mid-size Shopify store doing $500K-$2M in annual revenue with regular development needs.
        </p>
        <div class="bento-grid grid-cols-1 md:grid-cols-3">
          <!-- Retainer -->
          <div class="bento-tile border-2 border-primary-500/30 relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="px-3 py-1 bg-primary-500 text-white text-xs font-bold rounded-full">BEST VALUE</span>
            </div>
            <div class="text-center pt-4">
              <h3 class="text-xl font-bold text-primary-400 mb-1">Retainer</h3>
              <p class="text-sm text-muted-foreground mb-6">Predictable, proactive, all-inclusive</p>
            </div>
            <div class="space-y-3">
              <div class="flex justify-between">
                <span class="text-sm text-muted-foreground">Base monthly fee</span>
                <span class="text-sm font-medium text-foreground">${costBreakdown.retainer.monthly.toLocaleString()}/mo</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-muted-foreground">Annual base</span>
                <span class="text-sm font-medium text-foreground">${costBreakdown.retainer.annual.toLocaleString()}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-muted-foreground">Scope creep / extras</span>
                <span class="text-sm font-medium text-primary-400">$0 (included)</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-muted-foreground">Emergency fixes</span>
                <span class="text-sm font-medium text-primary-400">$0 (included)</span>
              </div>
              <div class="border-t border-border pt-3 mt-3">
                <div class="flex justify-between">
                  <span class="text-base font-bold text-foreground">Total Annual Cost</span>
                  <span class="text-base font-bold text-primary-400">${costBreakdown.retainer.total.toLocaleString()}</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Hourly -->
          <div class="bento-tile">
            <div class="text-center">
              <h3 class="text-xl font-bold text-foreground mb-1">Hourly</h3>
              <p class="text-sm text-muted-foreground mb-6">Pay per task, unpredictable costs</p>
            </div>
            <div class="space-y-3">
              <div class="flex justify-between">
                <span class="text-sm text-muted-foreground">Average monthly billing</span>
                <span class="text-sm font-medium text-foreground">${costBreakdown.hourly.monthly.toLocaleString()}/mo</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-muted-foreground">Annual base</span>
                <span class="text-sm font-medium text-foreground">${costBreakdown.hourly.annual.toLocaleString()}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-muted-foreground">Rush fees & overages</span>
                <span class="text-sm font-medium text-red-400">+${costBreakdown.hourly.extras.toLocaleString()}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-muted-foreground">Emergency fixes (rush rate)</span>
                <span class="text-sm font-medium text-red-400">+${costBreakdown.hourly.emergencies.toLocaleString()}</span>
              </div>
              <div class="border-t border-border pt-3 mt-3">
                <div class="flex justify-between">
                  <span class="text-base font-bold text-foreground">Total Annual Cost</span>
                  <span class="text-base font-bold text-red-400">${costBreakdown.hourly.total.toLocaleString()}</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Project-Based -->
          <div class="bento-tile">
            <div class="text-center">
              <h3 class="text-xl font-bold text-foreground mb-1">Project-Based</h3>
              <p class="text-sm text-muted-foreground mb-6">Fixed scope, no ongoing support</p>
            </div>
            <div class="space-y-3">
              <div class="flex justify-between">
                <span class="text-sm text-muted-foreground">2-3 projects/year</span>
                <span class="text-sm font-medium text-foreground">varies</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-muted-foreground">Annual project spend</span>
                <span class="text-sm font-medium text-foreground">${costBreakdown.project.annual.toLocaleString()}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-muted-foreground">Scope creep & change orders</span>
                <span class="text-sm font-medium text-red-400">+${costBreakdown.project.extras.toLocaleString()}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-muted-foreground">Emergency fixes (separate contract)</span>
                <span class="text-sm font-medium text-red-400">+${costBreakdown.project.emergencies.toLocaleString()}</span>
              </div>
              <div class="border-t border-border pt-3 mt-3">
                <div class="flex justify-between">
                  <span class="text-base font-bold text-foreground">Total Annual Cost</span>
                  <span class="text-base font-bold text-red-400">${costBreakdown.project.total.toLocaleString()}</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="bento-tile-muted p-6 mt-4 text-center">
          <p class="text-foreground font-semibold">
            Annual savings with a retainer: <span class="text-primary-400">${(costBreakdown.hourly.total - costBreakdown.retainer.total).toLocaleString()}</span> vs hourly
            and <span class="text-primary-400">${(costBreakdown.project.total - costBreakdown.retainer.total).toLocaleString()}</span> vs project-based
          </p>
        </div>
      </div>
    </section>

    <!-- Real-World Scenarios -->
    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold mb-3 text-foreground text-center">Real-World Scenarios</h2>
        <p class="text-center text-muted-foreground mb-8 max-w-2xl mx-auto">
          See how each billing model handles the situations Shopify merchants actually face.
        </p>

        {scenarios.map((scenario) => (
          <div class="bento-tile mb-4">
            <h3 class="text-xl font-bold text-foreground mb-2">{scenario.title}</h3>
            <p class="text-muted-foreground text-sm mb-6">{scenario.description}</p>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
              <div class="bento-tile-muted p-4 rounded-xl border-2 border-primary-500/20">
                <p class="text-xs font-semibold text-primary-400 uppercase tracking-wider mb-2">Retainer</p>
                <p class="text-sm text-foreground">{scenario.retainer}</p>
              </div>
              <div class="bento-tile-muted p-4 rounded-xl">
                <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2">Hourly</p>
                <p class="text-sm text-muted-foreground">{scenario.hourly}</p>
              </div>
              <div class="bento-tile-muted p-4 rounded-xl">
                <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2">Project-Based</p>
                <p class="text-sm text-muted-foreground">{scenario.project}</p>
              </div>
            </div>

            <div class="bg-red-500/5 border border-red-500/20 rounded-lg px-4 py-2">
              <p class="text-sm text-red-400">
                <span class="font-semibold">Cost of not having a retainer:</span> {scenario.lost}
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Who Should Choose What -->
    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold mb-8 text-foreground text-center">Which Model Fits Your Store?</h2>
        <div class="bento-grid grid-cols-1 md:grid-cols-3">
          <div class="bento-tile-accent">
            <h3 class="text-xl font-bold mb-3">Choose Retainer If...</h3>
            <ul class="space-y-2 text-sm text-white/80">
              <li>You do $200K+ in annual revenue</li>
              <li>You need regular updates and features</li>
              <li>Downtime directly costs you money</li>
              <li>You want proactive optimization, not reactive fixes</li>
              <li>You're preparing for growth or seasonal peaks</li>
              <li>You want a team that knows your store deeply</li>
            </ul>
            <a href="/retainer" class="inline-block mt-6 px-6 py-3 bg-white text-primary-600 font-semibold rounded-lg hover:bg-white/90 transition-colors text-sm">
              View Retainer Plans
            </a>
          </div>

          <div class="bento-tile">
            <h3 class="text-xl font-bold mb-3 text-foreground">Choose Hourly If...</h3>
            <ul class="space-y-2 text-sm text-muted-foreground">
              <li>You're a brand-new store with minimal needs</li>
              <li>You need a one-off fix (under 5 hours)</li>
              <li>You're testing a developer before committing</li>
              <li>Your store has very low traffic and revenue</li>
            </ul>
            <p class="text-xs text-muted-foreground mt-6 italic">
              Most stores outgrow hourly billing within 3-6 months.
            </p>
          </div>

          <div class="bento-tile">
            <h3 class="text-xl font-bold mb-3 text-foreground">Choose Project-Based If...</h3>
            <ul class="space-y-2 text-sm text-muted-foreground">
              <li>You need a complete store build from scratch</li>
              <li>You're doing a one-time migration</li>
              <li>The scope is clearly defined with no ongoing needs</li>
              <li>You already have in-house support for maintenance</li>
            </ul>
            <p class="text-xs text-muted-foreground mt-6 italic">
              Even project clients benefit from adding a retainer after launch.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Transition CTA -->
    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Stop Overpaying for Shopify Support?</h2>
          <p class="text-white/70 max-w-2xl mx-auto mb-8">
            Most merchants who switch from hourly or project-based billing to a retainer
            save 20-40% in the first year while getting better service and faster turnaround.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/retainer" class="inline-block px-8 py-4 bg-white text-primary-600 font-semibold rounded-lg hover:bg-white/90 transition-colors">
              View Retainer Plans
            </a>
            <a href="/contact" class="inline-block px-8 py-4 border border-white/30 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors">
              Book a Free Consultation
            </a>
          </div>
        </div>
      </div>
    </section>

    <FAQSection faqs={faqs} />
    <CTABottom />
  </div>
</Layout>
