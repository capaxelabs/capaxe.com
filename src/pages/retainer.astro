---
import Layout from "@/layouts/Layout.astro";
import { siteConfig } from "@/config/site";
import RetainerPlansSection from "@/components/RetainerPlan";
import BenefitSection from "@/components/BenefitSection";
import CTABottom from "@/components/CTA.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import FAQSection from "@/components/FAQSection.astro";
import { createSEO } from "@/utils/seo";
import type { SEOProps } from "@/utils/seo";
import { getFAQPageSchema } from "@/lib/schemas";
import { getCollection } from "astro:content";

const retainerPosts = (await getCollection("blog"))
  .filter(post => post.data.category === "Retainer")
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

interface Props {
  seo?: SEOProps;
  title?: string;
  description?: string;
}

const retainerFaqs = [
  { question: "What's included in the retainer hours?", answer: "Retainer hours can be used for development, maintenance, bug fixes, feature enhancements, and consultations related to your Shopify store." },
  { question: "Can I roll over unused hours?", answer: "Unused hours typically expire at the end of each month, but we can discuss rollover options for specific circumstances." },
  { question: "How do I request changes or support?", answer: "Retainer clients have access to a dedicated support channel where you can submit requests and track progress." },
  { question: "Can I upgrade my plan later?", answer: "Yes, you can upgrade your retainer plan at any time as your business needs grow." },
];

const seo = createSEO({
  pageName: "Shopify Development Retainer Plans — Ongoing Support",
  description: "Flexible Shopify development retainer plans with dedicated developers, priority support, and strategic guidance. No long-term contracts. Book a free consultation.",
  keywords: "Shopify retainer plan, dedicated Shopify developer, Shopify support plan, monthly Shopify maintenance, Shopify development retainer",
  pathname: "/retainer",
});
seo.structuredData = getFAQPageSchema(retainerFaqs);
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <!-- Hero -->
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span
            class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20"
          >
            Membership Plans
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4">
            Shopify Retainer Plans
          </h1>
          <p class="text-lg text-white/60 max-w-2xl mx-auto">
            Get dedicated development support, strategic guidance, and priority
            service with our flexible membership plans.
          </p>
        </div>
      </div>
    </section>

    <BenefitSection client:load />
    <RetainerPlansSection client:load />

    <!-- Why Choose -->
    <section class="py-4 px-6">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold mb-4 text-foreground text-center">
          Why Choose a Retainer Plan?
        </h2>
        <div class="bento-grid grid-cols-1 md:grid-cols-3 mt-6">
          <div class="bento-tile">
            <h3 class="text-lg font-semibold mb-2 text-foreground">
              Ongoing Support
            </h3>
            <p class="text-sm text-muted-foreground">
              Get reliable, consistent support for your Shopify store with
              dedicated experts who understand your business.
            </p>
          </div>
          <div class="bento-tile-accent">
            <h3 class="text-lg font-semibold mb-2">Predictable Costs</h3>
            <p class="text-sm text-white/70">
              Budget effectively with fixed monthly or yearly rates, avoiding
              unexpected development expenses.
            </p>
          </div>
          <div class="bento-tile">
            <h3 class="text-lg font-semibold mb-2 text-foreground">
              Priority Service
            </h3>
            <p class="text-sm text-muted-foreground">
              Enjoy faster response times and priority scheduling for your
              Shopify store needs.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Retainer Blog Posts -->
    <section class="py-4 px-6">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold mb-2 text-foreground text-center">Retainer Resources</h2>
        <p class="text-center text-muted-foreground mb-8 max-w-2xl mx-auto text-sm">
          Everything you need to know about Shopify retainer plans — pricing, ROI, what's included, and how to choose the right agency.
        </p>
        <div class="bento-grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
          {retainerPosts.map((post) => (
            <a href={`/blog/${post.id}`} class="bento-tile group p-0 overflow-hidden flex flex-col">
              {post.data.heroImage && (
                <div class="overflow-hidden aspect-[16/9]">
                  <img
                    width={720}
                    height={360}
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
              )}
              <div class="p-6 flex-1 flex flex-col">
                <div class="mb-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-primary-500/10 text-primary-400 text-xs font-medium">
                    <FormattedDate date={post.data.pubDate} />
                  </span>
                </div>
                <h3 class="text-lg font-bold mb-2 text-foreground group-hover:text-primary-400 transition-colors leading-snug">
                  {post.data.title}
                </h3>
                <p class="text-muted-foreground line-clamp-2 text-sm mb-4 leading-relaxed">{post.data.description}</p>
                <span class="mt-auto inline-flex items-center text-primary-400 text-sm font-medium group-hover:gap-2 transition-all gap-1">
                  Read article
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <FAQSection faqs={retainerFaqs} />

    <CTABottom />
  </div>
</Layout>
