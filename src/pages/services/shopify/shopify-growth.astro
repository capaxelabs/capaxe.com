---
import { FiTrendingUp, FiTarget, FiBarChart2, FiUsers } from "react-icons/fi";
import CTABottom from "@/components/CTA.astro";
import Layout from "@/layouts/Layout.astro";
import ServiceCTA from "@/components/ServiceCTA";
import { createSEO } from "@/utils/seo";

const seo = createSEO({
  pageName: "Shopify Growth & Strategy",
  description: "Strategic growth services for Shopify stores to increase traffic, improve conversion rates, and maximize revenue through data-driven optimization.",
  keywords: "shopify growth, ecommerce strategy, conversion rate optimization, revenue growth, shopify marketing, data-driven optimization",
  image: "/images/services/shopify-growth.jpg",
  contentType: "service",
  pathname: "/services/shopify-growth"
});
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20">
            Growth Strategy
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4">Shopify Growth & Strategy</h1>
          <p class="text-lg text-white/60 max-w-2xl mx-auto">
            Accelerate your Shopify store's growth with our data-driven strategies designed to increase traffic, improve conversion rates, and maximize revenue.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-grid grid-cols-1 sm:grid-cols-2">
          <div class="bento-tile-accent sm:col-span-2 text-center">
            <FiTrendingUp className="text-3xl text-white/80 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold mb-2">Growth Strategy</h2>
            <p class="text-sm text-white/70">Comprehensive growth plans tailored to your business goals and target audience.</p>
          </div>
          <div class="bento-tile text-center">
            <FiTarget className="text-3xl text-primary-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Conversion Optimization</h2>
            <p class="text-sm text-muted-foreground">Data-driven improvements to increase your store's conversion rate and average order value.</p>
          </div>
          <div class="bento-tile text-center">
            <FiBarChart2 className="text-3xl text-emerald-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Analytics & Reporting</h2>
            <p class="text-sm text-muted-foreground">Detailed analytics setup and regular reporting to track performance and identify opportunities.</p>
          </div>
          <div class="bento-tile text-center">
            <FiUsers className="text-3xl text-amber-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Customer Retention</h2>
            <p class="text-sm text-muted-foreground">Strategies to increase customer lifetime value through loyalty programs and personalized experiences.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold text-foreground mb-6 text-center">Our Growth Approach</h2>
        <div class="bento-grid grid-cols-1 md:grid-cols-3">
          <div class="bento-tile">
            <div class="text-primary-400 text-4xl font-bold mb-4">1</div>
            <h3 class="text-xl font-semibold text-foreground mb-3">Audit & Analysis</h3>
            <p class="text-sm text-muted-foreground">We conduct a comprehensive audit of your store to identify strengths, weaknesses, and growth opportunities.</p>
          </div>
          <div class="bento-tile">
            <div class="text-primary-400 text-4xl font-bold mb-4">2</div>
            <h3 class="text-xl font-semibold text-foreground mb-3">Strategy Development</h3>
            <p class="text-sm text-muted-foreground">We create a customized growth strategy with specific tactics and measurable goals based on our analysis.</p>
          </div>
          <div class="bento-tile">
            <div class="text-primary-400 text-4xl font-bold mb-4">3</div>
            <h3 class="text-xl font-semibold text-foreground mb-3">Implementation & Optimization</h3>
            <p class="text-sm text-muted-foreground">We implement the strategy, continuously monitor results, and make data-driven optimizations to maximize ROI.</p>
          </div>
        </div>
      </div>
    </section>
    <ServiceCTA />
  </div>
  <CTABottom />
</Layout>
