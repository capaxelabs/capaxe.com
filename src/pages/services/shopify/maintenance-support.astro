---
import Layout from "@/layouts/Layout.astro";
import ServiceCTA from "@/components/ServiceCTA";
import CTABottom from "@/components/CTA.astro";
import FAQSection from "@/components/FAQSection.astro";
import { createSEO } from "@/utils/seo";

const faqs = [
  { question: "What does Shopify maintenance include?", answer: "Our maintenance covers theme updates, security patches, performance monitoring, bug fixes, and regular backups. We keep your store running smoothly so you can focus on sales." },
  { question: "How quickly do you respond to urgent issues?", answer: "Critical issues get a response within 2-4 hours during business days. We also offer priority support plans with faster SLAs for high-traffic stores." },
  { question: "Do you offer monthly maintenance plans?", answer: "Yes, we offer flexible retainer plans with a set number of hours per month for ongoing updates, fixes, and small feature additions." },
  { question: "Can you help with Shopify app updates and compatibility?", answer: "Absolutely. We test app updates before applying them, resolve conflicts between apps, and ensure everything works together after Shopify platform updates." },
  { question: "Will maintenance affect my store's uptime?", answer: "No. We perform updates during low-traffic periods and test changes on staging environments first. Your customers won't experience any disruption." },
];

const seo = createSEO({
  pageName: "Shopify Maintenance",
  description: "Keep your Shopify store running at peak performance with our ongoing maintenance and support services. We handle theme updates, security patches, performance optimization, and custom development so you can focus on growing your business.",
  keywords: "shopify maintenance, ecommerce maintenance, website maintenance, shopify support, e-commerce maintenance",
  image: "/images/services/shopify-maintenance.jpg",
  contentType: "service",
  pathname: "/services/shopify/maintenance-support"
});
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20">
            Ongoing Support
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4">Maintenance & Support</h1>
          <p class="text-lg text-white/60 max-w-2xl mx-auto">
            Custom Shopify solutions to help your business grow online with reliable maintenance and expert support.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-grid grid-cols-1 md:grid-cols-3">
          <div class="bento-tile text-center">
            <h2 class="text-xl font-semibold text-foreground mb-2">Custom Theme Development</h2>
            <p class="text-sm text-muted-foreground">Unique, responsive themes tailored to your brand and business needs.</p>
          </div>
          <div class="bento-tile-accent text-center">
            <h2 class="text-xl font-semibold mb-2">App Development</h2>
            <p class="text-sm text-white/70">Custom Shopify apps to extend your store's functionality.</p>
          </div>
          <div class="bento-tile text-center">
            <h2 class="text-xl font-semibold text-foreground mb-2">Store Optimization</h2>
            <p class="text-sm text-muted-foreground">Performance optimization and conversion rate improvements.</p>
          </div>
        </div>
      </div>
    </section>
    <FAQSection faqs={faqs} />
    <ServiceCTA />
  </div>
  <CTABottom />
</Layout>
