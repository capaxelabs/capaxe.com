---
import { FiCode, FiTool, FiCloud } from "react-icons/fi";
import CTABottom from "@/components/CTA.astro";
import Layout from "@/layouts/Layout.astro";
import ServiceCTA from "@/components/ServiceCTA";
import FAQSection from "@/components/FAQSection.astro";
import { createSEO } from "@/utils/seo";

const faqs = [
  { question: "Do you build native or cross-platform mobile apps?", answer: "We build both. We use React Native for cross-platform apps that work on iOS and Android from a single codebase, and native development when platform-specific features require it." },
  { question: "Can you build a mobile app for my Shopify store?", answer: "Yes. We build mobile shopping apps that connect to your Shopify store via the Storefront API, providing a native experience with push notifications, offline support, and fast checkout." },
  { question: "How long does mobile app development take?", answer: "A basic mobile app takes 6-10 weeks. Feature-rich apps with custom integrations take 10-16 weeks. We deliver in iterative sprints with regular demos." },
  { question: "Do you handle app store submissions?", answer: "Yes. We manage the full submission process for both the Apple App Store and Google Play Store, including compliance requirements, listing optimization, and review feedback." },
  { question: "Can you build a progressive web app (PWA) instead?", answer: "Absolutely. PWAs offer app-like experiences through the browser without app store distribution. They work offline, send push notifications, and install on home screens." },
];

const seo = createSEO({
  pageName: "Mobile App Development",
  description: "Professional mobile app development services for iOS and Android platforms, helping businesses create seamless mobile experiences for their customers.",
  keywords: "mobile app development, iOS app development, Android app development, cross-platform apps",
  image: "/images/services/mobile-app-development.jpg",
  contentType: "service",
  pathname: "/services/mobile-app-development",
});
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20">
            App Development
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4">Mobile App Development</h1>
          <p class="text-lg text-white/60 max-w-2xl mx-auto">
            Take your Shopify store to the next level with our expert app development services. Whether it's a custom app tailored to your business needs or a public app designed to serve thousands of merchants, we've got you covered.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-grid grid-cols-1 md:grid-cols-3">
          <div class="bento-tile md:col-span-2 text-center">
            <FiCode className="text-3xl text-primary-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Custom App Development</h2>
            <p class="text-sm text-muted-foreground">Build apps tailored to your specific requirements, integrating unique features that make your store stand out.</p>
          </div>
          <div class="bento-tile-accent text-center">
            <FiTool className="text-3xl text-white/80 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold mb-2">Public App Development</h2>
            <p class="text-sm text-white/70">Create scalable public apps that can be listed on the Shopify App Store to reach a global audience.</p>
          </div>
          <div class="bento-tile text-center">
            <FiCloud className="text-3xl text-violet-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Seamless Integrations</h2>
            <p class="text-sm text-muted-foreground">Integrate third-party tools and services seamlessly into your Shopify store for enhanced functionality.</p>
          </div>
        </div>
      </div>
    </section>
    <FAQSection faqs={faqs} />
    <ServiceCTA />
  </div>
  <CTABottom />
</Layout>
