---
import { FiLayout, FiMonitor, FiSmartphone, FiPenTool } from "react-icons/fi";
import CTABottom from "@/components/CTA.astro";
import Layout from "@/layouts/Layout.astro";
import ServiceCTA from "@/components/ServiceCTA";
import FAQSection from "@/components/FAQSection.astro";
import { createSEO } from "@/utils/seo";

const faqs = [
  { question: "Do you design custom Shopify themes or customize existing ones?", answer: "We do both. We build fully custom themes from scratch and also customize existing Shopify themes to match your brand identity and conversion goals." },
  { question: "How long does a Shopify design project take?", answer: "A custom theme design takes 4-8 weeks depending on complexity. Theme customizations typically take 1-3 weeks. We provide a detailed timeline during the discovery phase." },
  { question: "Will my Shopify store be mobile-friendly?", answer: "Absolutely. Every design we create is fully responsive and optimized for mobile, tablet, and desktop. Over 70% of e-commerce traffic comes from mobile devices." },
  { question: "Can you redesign my existing Shopify store?", answer: "Yes. We audit your current store's design and UX, identify areas for improvement, and implement a redesign that improves both aesthetics and conversion rates." },
  { question: "Do you follow Shopify's Online Store 2.0 standards?", answer: "Yes. All our themes are built with Online Store 2.0 features including app blocks, sections everywhere, and JSON templates for maximum flexibility." },
];

const seo = createSEO({
  pageName: "Shopify Design Services",
  description: "Professional Shopify design services to create stunning, conversion-focused storefronts that reflect your brand identity and drive sales.",
  keywords: "shopify design, ecommerce design, UI/UX design, responsive design, mobile-friendly design, custom shopify themes",
  image: "/images/services/shopify-design.jpg",
  contentType: "service",
  pathname: "/services/shopify-design"
});
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20">
            Design Services
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4">Shopify Design Services</h1>
          <p class="text-lg text-white/60 max-w-2xl mx-auto">
            Create a stunning, conversion-focused Shopify store that reflects your brand identity and drives sales with our professional design services.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-grid grid-cols-1 sm:grid-cols-2">
          <div class="bento-tile-accent sm:col-span-2 text-center">
            <FiLayout className="text-3xl text-white/80 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold mb-2">Custom Theme Design</h2>
            <p class="text-sm text-white/70">Unique, responsive themes tailored to your brand identity and business goals.</p>
          </div>
          <div class="bento-tile text-center">
            <FiMonitor className="text-3xl text-primary-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">UI/UX Design</h2>
            <p class="text-sm text-muted-foreground">User-centered design that enhances customer experience and increases conversions.</p>
          </div>
          <div class="bento-tile text-center">
            <FiSmartphone className="text-3xl text-emerald-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Responsive Design</h2>
            <p class="text-sm text-muted-foreground">Mobile-friendly designs that provide a seamless experience across all devices.</p>
          </div>
          <div class="bento-tile text-center">
            <FiPenTool className="text-3xl text-amber-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Brand Identity</h2>
            <p class="text-sm text-muted-foreground">Cohesive visual identity including logos, color schemes, and typography.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold text-foreground mb-6 text-center">Our Design Process</h2>
        <div class="bento-grid grid-cols-1 md:grid-cols-3">
          <div class="bento-tile">
            <div class="text-primary-400 text-4xl font-bold mb-4">1</div>
            <h3 class="text-xl font-semibold text-foreground mb-3">Discovery & Research</h3>
            <p class="text-sm text-muted-foreground">We start by understanding your brand, target audience, and business goals to create a design strategy that aligns with your vision.</p>
          </div>
          <div class="bento-tile">
            <div class="text-primary-400 text-4xl font-bold mb-4">2</div>
            <h3 class="text-xl font-semibold text-foreground mb-3">Wireframing & Prototyping</h3>
            <p class="text-sm text-muted-foreground">We create wireframes and interactive prototypes to visualize the user journey and optimize the shopping experience.</p>
          </div>
          <div class="bento-tile">
            <div class="text-primary-400 text-4xl font-bold mb-4">3</div>
            <h3 class="text-xl font-semibold text-foreground mb-3">Visual Design & Implementation</h3>
            <p class="text-sm text-muted-foreground">We develop the final visual design and implement it on your Shopify store, ensuring it's pixel-perfect and fully responsive.</p>
          </div>
        </div>
      </div>
    </section>
    <FAQSection faqs={faqs} />
    <ServiceCTA />
  </div>
  <CTABottom />
</Layout>
