---
import { FiCode, FiLayers, FiServer, FiBox } from "react-icons/fi";
import CTABottom from "@/components/CTA.astro";
import Layout from "@/layouts/Layout.astro";
import ServiceCTA from "@/components/ServiceCTA";
import { createSEO } from "@/utils/seo";

const seo = createSEO({
  pageName: "Store Development",
  description: "Build a powerful Shopify store tailored to your business. From Liquid themes and Hydrogen storefronts to headless architectures with Next.js and Remix, we deliver end-to-end custom store development.",
  keywords: "shopify store development, custom shopify stores, shopify development services, e-commerce store development, liquid themes, hydrogen, headless shopify",
  image: "/images/services/store-development.jpg",
  contentType: "service",
  pathname: "/services/store-development"
});
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20">
            Store Development
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4">Custom Shopify Store Development</h1>
          <p class="text-lg text-white/60 max-w-2xl mx-auto">
            Build a powerful and engaging Shopify store tailored to your business needs. Whether you prefer a traditional Liquid theme or a modern headless approach, we've got you covered.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-grid grid-cols-1 lg:grid-cols-3">
          <div class="bento-tile md:col-span-2 text-center">
            <FiCode className="text-3xl text-primary-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Liquid Theme Development</h2>
            <p class="text-sm text-muted-foreground">Craft visually stunning Shopify stores using Liquid, Shopify's native templating language, for optimized performance and seamless integration.</p>
          </div>
          <div class="bento-tile-accent text-center">
            <FiLayers className="text-3xl text-white/80 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold mb-2">Hydrogen + Oxygen Deployment</h2>
            <p class="text-sm text-white/70">Build modern, fast, and personalized storefronts using Hydrogen and deploy them on Shopify's Oxygen hosting platform for unmatched scalability.</p>
          </div>
          <div class="bento-tile text-center">
            <FiServer className="text-3xl text-violet-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Headless Storefront Development</h2>
            <p class="text-sm text-muted-foreground">Leverage frameworks like Next.js, React.js, and Remix to create fully headless Shopify stores, offering ultimate flexibility and speed.</p>
          </div>
          <div class="bento-tile text-center">
            <FiBox className="text-3xl text-amber-400 mb-4 mx-auto" />
            <h2 class="text-xl font-semibold text-foreground mb-2">Custom Features & Integrations</h2>
            <p class="text-sm text-muted-foreground">Enhance your store with tailor-made features and seamless integrations to align with your unique business objectives.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-muted p-8">
          <h2 class="text-3xl font-bold text-foreground mb-4">Why Choose Us?</h2>
          <p class="text-sm text-muted-foreground max-w-3xl">
            From traditional Liquid themes to cutting-edge headless solutions, we provide end-to-end Shopify store development services. Our expertise in Hydrogen and Oxygen ensures that your storefront is fast, scalable, and future-ready.
          </p>
        </div>
      </div>
    </section>
    <ServiceCTA />
  </div>
  <CTABottom />
</Layout>
