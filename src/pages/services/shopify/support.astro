---
import Layout from "@/layouts/Layout.astro";
import CTABottom from "@/components/CTA.astro";
import ServiceCTA from "@/components/ServiceCTA";
import { createSEO } from "@/utils/seo";

const seo = createSEO({
  pageName: "Shopify Technical Support",
  description: "Expert technical support for your Shopify store. We provide priority assistance, regular maintenance, security updates, and fast troubleshooting to keep your digital presence running smoothly.",
  keywords: "technical support, Priority Support, expert support, digital presence, website support, e-commerce support",
  image: "/images/services/technical-support.jpg",
  contentType: "service",
  pathname: "/services/support"
});
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20">
            Priority Support
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4">Technical Support</h1>
          <p class="text-lg text-white/60 max-w-2xl mx-auto">
            Expert technical support for your digital presence, available when you need it most.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-grid grid-cols-1 md:grid-cols-3">
          <div class="bento-tile text-center">
            <h2 class="text-xl font-semibold text-foreground mb-2">Priority Support</h2>
            <p class="text-sm text-muted-foreground">Round-the-clock technical support for your critical business needs.</p>
          </div>
          <div class="bento-tile-accent text-center">
            <h2 class="text-xl font-semibold mb-2">Maintenance Services</h2>
            <p class="text-sm text-white/70">Regular updates, security patches, and performance optimization.</p>
          </div>
          <div class="bento-tile text-center">
            <h2 class="text-xl font-semibold text-foreground mb-2">Expert Troubleshooting</h2>
            <p class="text-sm text-muted-foreground">Quick resolution of technical issues and expert problem-solving.</p>
          </div>
        </div>
      </div>
    </section>
    <ServiceCTA />
  </div>
  <CTABottom />
</Layout>
