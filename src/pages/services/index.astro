---
import Layout from "../../layouts/Layout.astro";
import { siteConfig } from "@/config/site";
import CTABottom from "@/components/CTA.astro";
import ServiceCTA from "@/components/ServiceCTA";
import FAQSection from "@/components/FAQSection.astro";
import { createSEO } from "@/utils/seo";
import type { SEOProps } from "@/utils/seo";

const faqs = [
  { question: "What Shopify development services do you provide?", answer: "We provide custom Shopify app development, Liquid theme builds, headless storefronts with Hydrogen, Shopify Plus enterprise solutions, platform migrations, and ongoing store maintenance." },
  { question: "Do you build custom Shopify apps?", answer: "Yes, we build both private and public Shopify apps using the Admin API, Storefront API, Shopify Functions, and Polaris with TypeScript and React." },
  { question: "Can you build a headless Shopify storefront?", answer: "Yes, we build headless storefronts using Shopify Hydrogen, Next.js, and Remix connected to the Storefront API for full control over design and performance." },
  { question: "Do you work with Shopify Plus stores?", answer: "Yes, we specialize in Shopify Plus development including custom checkout, B2B commerce, Shopify Functions, and international selling with Shopify Markets." },
  { question: "How do I get started with a Shopify project?", answer: "Book a free 30-minute discovery call where we discuss your requirements, timeline, and budget. We then provide a detailed proposal with scope and pricing." },
];

interface Props {
  seo?: SEOProps;
  title?: string;
  description?: string;
}
const seo = createSEO({
  pageName: "Shopify Development Services — Apps, Stores & Headless",
  description: "Custom Shopify app development, store builds, headless commerce, migration, and ongoing support. Serving brands globally from India. Get a free consultation.",
  keywords: "Shopify development services, custom Shopify apps, Shopify store development, e-commerce development, Shopify migration, headless commerce",
  image: "/images/services/services.jpg",
  contentType: "service",
  pathname: "/services",
});
---

<Layout seo={seo}>
  <div class="min-h-screen">
    <!-- Hero -->
    <section class="pt-32 pb-8 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-tile-accent text-center py-16">
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 text-xs font-medium mb-4 border border-white/20">
            Our Expertise
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4">Shopify Development Services</h1>
          <p class="text-lg text-white/60 max-w-2xl mx-auto">
            {siteConfig.services.shopify.description}
          </p>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="pb-16 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bento-grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
          {
            siteConfig.services.shopify.items.map((service: any, index: number) => (
              <a href={service.href} class={`bento-tile group ${index === 0 ? 'md:col-span-2' : ''}`}>
                <div class="w-10 h-10 bg-primary-500/20 rounded-xl flex items-center justify-center mb-4">
                  <div class="w-2.5 h-2.5 rounded-full bg-primary-400" />
                </div>
                <h3 class="text-xl font-semibold mb-3 text-foreground group-hover:text-primary-300 transition-colors">{service.title}</h3>
                <p class="text-sm text-muted-foreground">{service.description}</p>
              </a>
            ))
          }
        </div>
      </div>
    </section>
    <FAQSection faqs={faqs} />
    <ServiceCTA />
  </div>
  <CTABottom />
</Layout>
