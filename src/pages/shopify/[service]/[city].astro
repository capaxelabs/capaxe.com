---
import Layout from "@/layouts/Layout.astro";
import CTABottom from "@/components/CTA.astro";
import FAQSchema from "@/components/FAQSchema.astro";
import { createSEO } from "@/utils/seo";
import { siteConfig } from "@/config/site";
import {
  pseoServices,
  pseoCities,
  type PSEOService,
  type PSEOCity,
  buildTargetKeywords
} from "@/config/pseo";

interface Props {
  service: PSEOService;
  city: PSEOCity;
  uniqueValueProp: string;
}

export function getStaticPaths() {
  return pseoServices.flatMap((service, serviceIndex) =>
    pseoCities.map((city, cityIndex) => ({
      params: { service: service.slug, city: city.slug },
      props: {
        service,
        city,
        uniqueValueProp:
          service.uniqueValueProps[(serviceIndex + cityIndex) % service.uniqueValueProps.length]
      }
    }))
  );
}

const { service, city, uniqueValueProp } = Astro.props as Props;

const serviceBenefit = service.serviceBenefit;
const localChallenge = city.localChallenge;
const targetKeywords = buildTargetKeywords(service, city);
const keywords = targetKeywords.join(", ");

const seo = createSEO({
  pageName: `${service.name} in ${city.name}`,
  description: `${service.metaDescription} We help ${city.name} brands overcome ${localChallenge}.`,
  keywords,
  pathname: `/shopify/${service.slug}/${city.slug}`,
  contentType: "service"
});

seo.structuredData = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.name,
  description: seo.description,
  provider: {
    "@type": "Organization",
    name: siteConfig.name,
    url: siteConfig.url
  },
  serviceType: service.name,
  areaServed: {
    "@type": "City",
    name: city.name
  }
};

const faqs = [
  {
    question: `Why do I need ${service.name.toLowerCase()} services in ${city.name}?`,
    answer: `${city.name} brands face ${localChallenge}. ${city.commerceStat} Professional ${service.name.toLowerCase()} ensures your Shopify store is optimised for ${serviceBenefit}.`
  },
  {
    question: `What payment methods do ${city.name} shoppers expect?`,
    answer: `${city.name} shoppers primarily pay with ${city.paymentGateways.slice(0, 3).join(", ")}. We integrate all major gateways for your market, ensuring checkout abandonment stays low across every payment preference.`
  },
  {
    question: `How long does ${service.name.toLowerCase()} take for a ${city.name} store?`,
    answer: `Timelines depend on project scope. Simple projects take 1–2 weeks, while complex builds or migrations can take 4–12 weeks. We provide a detailed timeline during discovery.`
  },
  {
    question: `What makes Capaxe different from other Shopify agencies serving ${city.name}?`,
    answer: `We combine deep technical expertise with an understanding of ${city.name}'s market dynamics. Our focus is on ${uniqueValueProp}, delivering measurable results for ${city.name} businesses.`
  },
  {
    question: "How do I get started with Capaxe?",
    answer: `Contact us for a free project consultation. We will assess your current platform, discuss your goals for the ${city.name} market, and provide a detailed plan with timeline and pricing.`
  },
];
---

<Layout seo={seo}>
  <!-- Hero -->
  <section class="pt-32 pb-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto space-y-6">
      <h1 class="text-4xl md:text-5xl font-bold">
        Premier {service.name} Experts in {city.name}
      </h1>
      <p class="text-lg text-muted-foreground">
        Are you an e-commerce brand based in {city.name} looking to maximise your Shopify investment?
        Capaxe is your specialised partner for high-performance {service.name.toLowerCase()} services.
        We understand the specific demands of {localChallenge} and deliver tailored solutions that
        translate directly into {serviceBenefit}.
      </p>
      <div class="flex flex-wrap gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-primary-500/10 text-primary-600 text-sm font-medium border border-primary-500/20">
          {city.currency} · {city.timezone.split("/")[1]?.replace(/_/g, " ")}
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-foreground/5 text-muted-foreground text-sm border border-foreground/10">
          Population: {city.population}
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-foreground/5 text-muted-foreground text-sm border border-foreground/10">
          Support hours: {city.supportHours}
        </span>
      </div>
    </div>
  </section>

  <!-- Market intelligence -->
  <section class="py-16 px-4 bg-foreground/5">
    <div class="max-w-5xl mx-auto space-y-8">
      <h2 class="text-3xl font-semibold">The {city.name} E-commerce Market</h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bento-tile space-y-3">
          <h3 class="text-lg font-semibold">Market Stat</h3>
          <p class="text-muted-foreground">{city.commerceStat}</p>
        </div>
        <div class="bento-tile space-y-3">
          <h3 class="text-lg font-semibold">Shopper Behaviour</h3>
          <p class="text-muted-foreground">{city.marketContext}</p>
        </div>
      </div>

      <div class="bento-tile space-y-4">
        <h3 class="text-lg font-semibold">Preferred Payment Methods in {city.name}</h3>
        <p class="text-sm text-muted-foreground">
          We integrate every gateway your {city.name} customers rely on — so checkout conversion stays high regardless of how they pay.
        </p>
        <div class="flex flex-wrap gap-2">
          {city.paymentGateways.map(gateway => (
            <span class="inline-block px-3 py-1 rounded-full bg-primary-500/10 text-primary-600 text-sm font-medium border border-primary-500/20">
              {gateway}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Why localised service matters -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto space-y-4">
      <h2 class="text-3xl font-semibold">Why Localised {service.name} Matters in {city.name}</h2>
      <p class="text-lg text-muted-foreground">
        In a rapidly moving market like {city.name}, generic solutions won&apos;t cut it. Your e-commerce
        store needs to be more than just functional — it needs to be an optimised revenue engine built
        for how {city.name} shoppers actually behave.
      </p>
      <p class="text-lg text-muted-foreground">
        Our team combines deep technical expertise with a clear understanding of {city.name}&apos;s
        local commerce dynamics. Whether you require a complete platform rebuild, a complex third-party
        app integration, or specialised performance tuning, we focus on delivering a {uniqueValueProp}.
        We don&apos;t just build or fix; we architect for scale and conversion.
      </p>
    </div>
  </section>

  <!-- Process -->
  <section class="py-16 px-4 bg-foreground/5">
    <div class="max-w-5xl mx-auto space-y-6">
      <h2 class="text-3xl font-semibold">Our {service.name} Process</h2>
      <p class="text-lg text-muted-foreground">
        Our approach is transparent, data-driven, and focused on tangible outcomes for {city.name} brands.
      </p>
      <ol class="space-y-6 list-decimal list-inside text-muted-foreground">
        <li class="space-y-2">
          <h3 class="text-2xl font-semibold text-foreground">Discovery &amp; Strategy</h3>
          <p>
            We begin with an in-depth assessment of your platform, goals, and target audience in {city.name}.
            This ensures our {service.name.toLowerCase()} plan aligns with your business KPIs and the
            expectations of {city.name} shoppers.
          </p>
        </li>
        <li class="space-y-2">
          <h3 class="text-2xl font-semibold text-foreground">Execution &amp; Quality Assurance</h3>
          <p>
            We execute the {service.name.toLowerCase()} work using best-in-class standards — clean
            Liquid architecture, 100% data fidelity for migrations, and Core Web Vitals optimisation for
            speed projects. Every build is tested against {city.name} shopper behaviour patterns.
          </p>
        </li>
        <li class="space-y-2">
          <h3 class="text-2xl font-semibold text-foreground">Launch &amp; Post-Launch Support</h3>
          <p>
            Following rigorous testing, we handle a smooth deployment and provide guaranteed
            post-implementation support. Your {city.name} store will be monitored and backed by our team
            across {city.supportHours}.
          </p>
        </li>
      </ol>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto space-y-6">
      <h2 class="text-3xl font-semibold text-center">Frequently Asked Questions</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {faqs.map(faq => (
          <div class="bento-tile rounded-lg">
            <h3 class="text-base font-semibold mb-2">{faq.question}</h3>
            <p class="text-sm text-muted-foreground">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <FAQSchema faqs={faqs} />

  <!-- CTA -->
  <section class="py-16 px-4 bg-foreground/5">
    <div class="max-w-5xl mx-auto space-y-6 text-center">
      <h2 class="text-3xl font-semibold">Ready to Elevate Your Shopify Store in {city.name}?</h2>
      <p class="text-lg text-muted-foreground">
        Stop losing customers to slow load times or cumbersome checkout flows. Partner with Capaxe for
        expert {service.name.toLowerCase()} that gives you a competitive edge in {city.name}.
      </p>
      <a
        class="inline-flex items-center justify-center rounded-md bg-black px-6 py-3 text-foreground text-lg font-medium transition hover:bg-gray-800"
        href="/contact"
      >
        Contact us for a free consultation
      </a>
    </div>
  </section>

  <CTABottom />
</Layout>
