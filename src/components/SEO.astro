---
import type { SEOProps } from '@/utils/seo';
import { siteConfig } from '@/config/site';

interface Props extends SEOProps {}

const { 
  title = siteConfig.name, 
  description = siteConfig.description,
  image = "/og.jpg",
  keywords,
  canonical,
  type = "website",
  publishedTime,
  modifiedTime,
  author,
  noindex = false,
  nofollow = false,
  structuredData
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const canonicalURL = canonical || new URL(pathname, Astro.site).toString();

const segmentLabels: Record<string, string> = {
  services: 'Services',
  blog: 'Blog',
  'case-studies': 'Case Studies',
  about: 'About',
  contact: 'Contact',
  consultation: 'Consultation',
  retainer: 'Retainer Plans',
  faq: 'FAQ',
  'hire-shopify-developer': 'Hire a Shopify Developer',
  'shopify-plus': 'Shopify Plus',
  'shopify-support': 'Shopify Support',
  legal: 'Legal',
  locations: 'Locations',
  shopify: 'Shopify',
  press: 'Press',
  plans: 'Plans',
};

function generateBreadcrumbs(path: string) {
  if (path === '/' || path === '') return null;
  const segments = path.split('/').filter(Boolean);
  const items = [{ name: 'Home', url: siteConfig.url }];
  let currentPath = '';
  for (const segment of segments) {
    currentPath += `/${segment}`;
    const label = segmentLabels[segment] || segment.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
    items.push({ name: label, url: `${siteConfig.url}${currentPath}` });
  }
  return {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": items.map((item, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": item.name,
      "item": item.url
    }))
  };
}

const hasExistingBreadcrumb = structuredData && (
  Array.isArray(structuredData)
    ? structuredData.some((s: any) => s?.['@type'] === 'BreadcrumbList')
    : (structuredData as any)?.['@type'] === 'BreadcrumbList'
);

const autoBreadcrumb = !hasExistingBreadcrumb ? generateBreadcrumbs(pathname) : null;

const allStructuredData = [
  ...(structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : []),
  ...(autoBreadcrumb ? [autoBreadcrumb] : [])
].filter(Boolean);
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
{keywords && <meta name="keywords" content={keywords} />}

<!-- Robots directives -->
{noindex && nofollow ? (
  <meta name="robots" content="noindex, nofollow" />
) : noindex ? (
  <meta name="robots" content="noindex" />
) : nofollow ? (
  <meta name="robots" content="nofollow" />
) : (
  <meta name="robots" content="index, follow" />
)}

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:logo" content="/logo.svg" />
<meta property="og:image" content={new URL(image, Astro.site)} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{author && <meta property="article:author" content={author} />}


<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta property="twitter:domain" content="capaxe.com" />
<meta property="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, Astro.site)} />

<!-- Schema.org structured data -->
{allStructuredData.length > 0 && (
  allStructuredData.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
)}