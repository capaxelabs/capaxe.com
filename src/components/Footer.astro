---
import { siteConfig } from "@/config/site";
import { menuConfig } from "@/config/menu";

const currentYear = new Date().getFullYear();
---

<footer class="bg-card border-t border-border">
  <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
    <div class="bento-grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4">
      <div class="bento-tile lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <img src="/logo.svg" alt="Capaxe Labs" class="w-10 h-10" />
          <a href="/" class="text-2xl font-bold text-foreground">
            {siteConfig.name}
          </a>
        </div>
        <p class="text-muted-foreground max-w-xs text-sm leading-relaxed">
          {siteConfig.description}
        </p>
      </div>

      <div class="bento-tile">
        <h3
          class="text-sm font-semibold text-primary-400 uppercase tracking-wider"
        >
          Solutions
        </h3>
        <ul class="mt-4 space-y-3">
          {
            siteConfig.services.shopify.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                >
                  {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="bento-tile">
        <h3
          class="text-sm font-semibold text-primary-400 uppercase tracking-wider"
        >
          Case Studies
        </h3>
        <ul class="mt-4 space-y-3">
          {
            menuConfig.footerNav.caseStudies.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                >
                  {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="bento-tile">
        <h3
          class="text-sm font-semibold text-primary-400 uppercase tracking-wider"
        >
          Company
        </h3>
        <ul class="mt-4 space-y-3">
          {
            menuConfig.footerNav.company.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                >
                  {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Giant Brand Text -->
    <div class="mt-16 overflow-hidden" id="footer-brand">
      <div
        class="flex items-baseline justify-center gap-[2vw] leading-none select-none"
      >
        <span
          class="text-[14vw] md:text-[12vw] font-black tracking-tighter text-foreground footer-brand-capaxe"
        >
          Capaxe
        </span>
        <span
          class="text-[14vw] md:text-[12vw] font-black tracking-tighter text-primary-400/0 footer-brand-labs"
        >
          Labs
        </span>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-border">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <p class="text-sm text-muted-foreground">
          &copy; {currentYear}
          {siteConfig.name}. All rights reserved.
        </p>
        <div class="mt-4 md:mt-0">
          <ul class="flex space-x-6">
            {
              menuConfig.footerNav.legal.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                  >
                    {item.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  @keyframes labs-reveal {
    0% {
      clip-path: inset(0 100% 0 0);
      color: transparent;
    }
    50% {
      clip-path: inset(0 0 0 0);
      color: var(--color-primary-400);
    }
    100% {
      clip-path: inset(0 0 0 0);
      color: var(--color-primary-400);
    }
  }

  @keyframes capaxe-brighten {
    0% {
      opacity: 0.1;
    }
    100% {
      opacity: 0.15;
    }
  }

  .footer-brand-labs.animate-in {
    animation: labs-reveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .footer-brand-capaxe.animate-in {
    animation: capaxe-brighten 1s ease forwards;
  }
</style>

<script is:inline>
  (function () {
    function initFooterBrand() {
      var brand = document.getElementById("footer-brand");
      if (!brand) return;

      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var labs = brand.querySelector(".footer-brand-labs");
              var capaxe = brand.querySelector(".footer-brand-capaxe");
              if (labs) labs.classList.add("animate-in");
              if (capaxe) capaxe.classList.add("animate-in");
            }
          });
        },
        { threshold: 0.1 },
      );

      observer.observe(brand);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initFooterBrand);
    } else {
      initFooterBrand();
    }
  })();
</script>
