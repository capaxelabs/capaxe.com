---
import { ArrowRight } from "lucide-react";
import { Button } from "@/components/ui/button";
import ChatContactModal from "@/components/ChatContactModal";
import AuditModal from "@/components/AuditModal";
---

<section class="min-h-[90vh] relative flex items-center pt-24 pb-8">
  <div class="container max-w-7xl mx-auto px-6">
    <div class="bento-grid grid-cols-1 md:grid-cols-4 md:grid-rows-2">
      <!-- Main Hero Tile (spans 3 cols, 2 rows) -->
      <div
        class="bento-tile-accent md:col-span-3 md:row-span-2 flex flex-col justify-between min-h-105 relative overflow-hidden"
      >
        <div>
          <div class="flex items-center gap-3 mb-6 hero-animate">
            <div class="bg-white rounded-lg px-3 py-1.5 shadow-sm">
              <img
                src="/shopify-expert.png"
                alt="Shopify Expert Badge"
                class="h-6 w-auto"
                loading="lazy"
              />
            </div>
            <div class="bg-white rounded-lg px-3 py-1.5 shadow-sm">
              <img
                src="/shopify-partner.png"
                alt="Shopify Partner Badge"
                class="h-6 w-auto"
                loading="lazy"
              />
            </div>
          </div>
          <h1
            class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-2 hero-animate hero-animate-delay-1"
          >
            We Build Shopify Stores<br />
            <span class="text-white/80">That Outperform the Competition</span>
          </h1>
          <p
            class="text-xl text-white/70 mt-2 hero-animate hero-animate-delay-2"
          >
            Liquid themes &middot; Hydrogen storefronts &middot; <span
              class="font-semibold text-white">Custom apps</span
            >
          </p>
          <p
            class="text-base text-white/60 max-w-lg mt-6 hero-animate hero-animate-delay-3"
          >
            50+ stores shipped across DTC, fashion, and lifestyle brands — from
            theme builds to headless storefronts, on time, every time.
          </p>
        </div>
        <div
          class="flex flex-col sm:flex-row gap-3 mt-8 hero-animate hero-animate-delay-4"
        >
          <a href="/case-studies">
            <Button
              size="lg"
              className="bg-white text-primary-600 hover:bg-gray-100 font-semibold rounded-xl btn-shimmer"
            >
              View Our Work
              <ArrowRight className="ml-2 h-4 w-4" />
            </Button>
          </a>
          <ChatContactModal
            client:load
            className="bg-white/20 backdrop-blur-sm text-white px-6 py-3 rounded-xl font-medium hover:bg-white/30 transition-all duration-200 border border-white/20"
          >
            Start Your Project
          </ChatContactModal>
        </div>
        <!-- Decorative SVG illustration — bottom right -->
        <div
          class="hidden md:block absolute bottom-6 right-6 pointer-events-none opacity-30 hero-animate hero-animate-delay-4"
          aria-hidden="true"
        >
          <svg
            width="260"
            height="260"
            viewBox="0 0 480 480"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <style>
              @keyframes svg-float-slow {
                0%,
                100% {
                  transform: translateY(0px);
                }
                50% {
                  transform: translateY(-14px);
                }
              }
              @keyframes svg-float-fast {
                0%,
                100% {
                  transform: translateY(0px);
                }
                50% {
                  transform: translateY(-7px);
                }
              }
              @keyframes svg-pulse {
                0%,
                100% {
                  opacity: 0.06;
                  transform: scale(1);
                }
                50% {
                  opacity: 0.14;
                  transform: scale(1.04);
                }
              }
              .svg-float-slow {
                animation: svg-float-slow 6s ease-in-out infinite;
              }
              .svg-float-fast {
                animation: svg-float-fast 4s ease-in-out infinite;
              }
              .svg-pulse {
                animation: svg-pulse 5s ease-in-out infinite;
                transform-origin: 240px 245px;
              }
            </style>

            <!-- Ambient glow rings -->
            <circle cx="240" cy="245" r="175" fill="white" class="svg-pulse"
            ></circle>
            <circle
              cx="240"
              cy="245"
              r="105"
              fill="white"
              class="svg-pulse"
              style="animation-delay:2.5s;"></circle>

            <!-- Centre: Shopify storefront bag -->
            <g class="svg-float-slow">
              <!-- Handle -->
              <path
                d="M198 208 V170 C198 143 282 143 282 170 V208"
                fill="none"
                stroke="white"
                stroke-width="10"
                stroke-linecap="round"></path>
              <!-- Bag body -->
              <rect
                x="158"
                y="208"
                width="164"
                height="148"
                rx="18"
                fill="white"
                fill-opacity="0.1"
                stroke="white"
                stroke-width="10"></rect>
              <!-- Awning -->
              <rect
                x="144"
                y="198"
                width="192"
                height="30"
                rx="8"
                fill="white"
                fill-opacity="0.22"
                stroke="white"
                stroke-width="4"></rect>
              <!-- Scallops -->
              <path
                d="M144 228 Q160 245 176 228 Q192 245 208 228 Q224 245 240 228 Q256 245 272 228 Q288 245 304 228 Q320 245 336 228"
                fill="none"
                stroke="white"
                stroke-width="4"></path>
              <!-- Smile -->
              <path
                d="M212 295 Q240 322 268 295"
                fill="none"
                stroke="white"
                stroke-width="9"
                stroke-linecap="round"></path>
            </g>

            <!-- Top-left: Code tag -->
            <g class="svg-float-slow" style="animation-delay:1.8s;">
              <rect
                x="52"
                y="95"
                width="96"
                height="54"
                rx="14"
                fill="white"
                fill-opacity="0.12"
                stroke="white"
                stroke-width="4"></rect>
              <!-- < -->
              <path
                d="M74 117 L66 122 L74 127"
                fill="none"
                stroke="white"
                stroke-width="3.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <!-- / -->
              <line
                x1="96"
                y1="113"
                x2="88"
                y2="131"
                stroke="white"
                stroke-width="3.5"
                stroke-linecap="round"></line>
              <!-- > -->
              <path
                d="M106 117 L114 122 L106 127"
                fill="none"
                stroke="white"
                stroke-width="3.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </g>

            <!-- Top-right: Lightning bolt (speed) -->
            <g class="svg-float-fast" style="animation-delay:0.6s;">
              <circle
                cx="393"
                cy="122"
                r="36"
                fill="white"
                fill-opacity="0.12"
                stroke="white"
                stroke-width="4"></circle>
              <path
                d="M399 98 L384 126 L395 126 L389 148 L408 118 L396 118 Z"
                fill="white"
                fill-opacity="0.9"></path>
            </g>

            <!-- Bottom-left: Bar chart (results) -->
            <g class="svg-float-fast" style="animation-delay:1.1s;">
              <rect
                x="50"
                y="318"
                width="94"
                height="68"
                rx="14"
                fill="white"
                fill-opacity="0.12"
                stroke="white"
                stroke-width="4"></rect>
              <!-- Bars -->
              <rect
                x="68"
                y="354"
                width="13"
                height="18"
                rx="3"
                fill="white"
                fill-opacity="0.5"></rect>
              <rect
                x="87"
                y="342"
                width="13"
                height="30"
                rx="3"
                fill="white"
                fill-opacity="0.75"></rect>
              <rect x="106" y="330" width="13" height="42" rx="3" fill="white"
              ></rect>
            </g>

            <!-- Bottom-right: Checkmark (quality / on-time) -->
            <g class="svg-float-slow" style="animation-delay:3s;">
              <circle
                cx="392"
                cy="365"
                r="36"
                fill="white"
                fill-opacity="0.12"
                stroke="white"
                stroke-width="4"></circle>
              <path
                d="M376 365 L388 377 L412 350"
                fill="none"
                stroke="white"
                stroke-width="5.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </g>
          </svg>
        </div>
        <!-- Background glow -->
        <div
          class="absolute -bottom-20 -right-20 w-80 h-80 bg-white/10 rounded-full blur-3xl pointer-events-none"
        >
        </div>
      </div>

      <!-- Audit Tile -->
      <div
        style="opacity: 0; animation: fade-up 0.6s ease-out 0.35s forwards, border-rotate 3s linear infinite;"
      >
        <AuditModal
          client:load
          className="animate-border relative flex flex-col justify-between p-6 md:p-8 overflow-hidden group cursor-pointer text-left w-full h-full"
        >
          <span class="absolute top-3 right-3 flex h-3 w-3" aria-hidden="true">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
            ></span>
            <span
              class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"
            ></span>
          </span>

          <div>
            <span
              class="inline-block text-xs font-bold uppercase tracking-widest text-emerald-500 mb-3"
            >
              Free &middot; No commitment
            </span>
            <p class="text-xl font-bold text-foreground leading-snug mb-4">
              Free Speed &amp;<br />SEO Audit
            </p>
            <ul class="space-y-2">
              <li class="flex items-center gap-2 text-xs text-muted-foreground">
                <svg
                  class="h-3.5 w-3.5 text-emerald-500 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 13l4 4L19 7"></path>
                </svg>
                Speed &amp; Core Web Vitals
              </li>
              <li class="flex items-center gap-2 text-xs text-muted-foreground">
                <svg
                  class="h-3.5 w-3.5 text-emerald-500 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 13l4 4L19 7"></path>
                </svg>
                On-page SEO health
              </li>
              <li class="flex items-center gap-2 text-xs text-muted-foreground">
                <svg
                  class="h-3.5 w-3.5 text-emerald-500 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 13l4 4L19 7"></path>
                </svg>
                Technical SEO issues
              </li>
            </ul>
          </div>

          <span
            class="mt-5 inline-flex items-center gap-1.5 text-xs font-semibold text-primary-400 group-hover:gap-2.5 transition-all duration-300"
          >
            Get My Free Audit
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-3.5 w-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </span>
        </AuditModal>
      </div>

      <!-- Stats Tile -->
      <div
        class="bento-tile flex flex-col justify-between min-h-45"
        style="opacity: 0; animation: fade-up 0.6s ease-out 0.5s forwards;"
      >
        <span
          class="text-xs font-bold uppercase tracking-widest text-muted-foreground"
          >Track Record</span
        >
        <div class="grid grid-cols-2 gap-x-4 gap-y-5 mt-4">
          <div>
            <div class="text-3xl font-black text-foreground">50+</div>
            <div class="text-xs text-muted-foreground mt-0.5">Stores shipped</div>
          </div>
          <div>
            <div class="text-3xl font-black text-foreground">8+</div>
            <div class="text-xs text-muted-foreground mt-0.5">Years expertise</div>
          </div>
          <div>
            <div class="text-3xl font-black text-primary-400">100%</div>
            <div class="text-xs text-muted-foreground mt-0.5">On-time delivery</div>
          </div>
          <div>
            <div class="text-3xl font-black text-foreground">3</div>
            <div class="text-xs text-muted-foreground mt-0.5">Continents served</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
