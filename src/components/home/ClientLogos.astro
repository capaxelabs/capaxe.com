---
import { siteConfig } from "@/config/site";

const logos = siteConfig.clientLogos || [];
---

{logos.length > 0 && (
  <section class="py-12 reveal-on-scroll">
    <p class="text-xs font-semibold text-muted-foreground uppercase tracking-widest text-center mb-8">
      Trusted by Amazing Clients
    </p>

    <div
      class="overflow-hidden space-y-5"
      style="mask-image: linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%);"
    >
      <!-- Row 1: scroll left -->
      <div class="client-marquee-left flex items-center w-max">
        {[...logos, ...logos, ...logos].map((logo) => (
          <div class="px-10">
            <img
              src={logo.src}
              alt={logo.alt}
              class="h-9 w-auto object-contain grayscale opacity-55 shrink-0"
            />
          </div>
        ))}
      </div>

      <!-- Row 2: scroll right -->
      <div class="client-marquee-right flex items-center w-max">
        {[...logos, ...logos, ...logos].map((logo) => (
          <div class="px-10">
            <img
              src={logo.src}
              alt={logo.alt}
              class="h-9 w-auto object-contain grayscale opacity-55 shrink-0"
            />
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  @keyframes scroll-left {
    from { transform: translateX(0); }
    to { transform: translateX(-33.333%); }
  }
  @keyframes scroll-right {
    from { transform: translateX(-33.333%); }
    to { transform: translateX(0); }
  }
  .client-marquee-left {
    animation: scroll-left 22s linear infinite;
  }
  .client-marquee-right {
    animation: scroll-right 22s linear infinite;
  }
</style>
